a e potável, ela deve passar por um processo de purificação numa estação de tratamento de água. Nesse processo, as principais etapas são, nesta ordem: coagulação, decantação, filtração, desinfecção e fluoretação.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1847},"LeftTop":{"X":101,"Y":1491},"RightBottom":{"X":845,"Y":1847},"RightTop":{"X":845,"Y":1491}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"Qual é a etapa de retirada de grande parte desses sólidos?","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1958},"LeftTop":{"X":101,"Y":1877},"RightBottom":{"X":845,"Y":1958},"RightTop":{"X":845,"Y":1877}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"A Coagulação.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2034},"LeftTop":{"X":102,"Y":1994},"RightBottom":{"X":347,"Y":2034},"RightTop":{"X":347,"Y":1994}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"B Decantação.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2105},"LeftTop":{"X":102,"Y":2064},"RightBottom":{"X":347,"Y":2105},"RightTop":{"X":347,"Y":2064}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"C Filtração.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2180},"LeftTop":{"X":102,"Y":2135},"RightBottom":{"X":301,"Y":2180},"RightTop":{"X":301,"Y":2135}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"D Desinfecção.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2251},"LeftTop":{"X":102,"Y":2208},"RightBottom":{"X":354,"Y":2251},"RightTop":{"X":354,"Y":2208}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"E Fluoretação.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2