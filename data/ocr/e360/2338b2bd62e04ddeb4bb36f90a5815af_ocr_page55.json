{"PageNumber":55,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"Discard_type","Text":"Professor Fredão","Level":0,"Polygon":{"LeftBottom":{"X":740,"Y":192},"LeftTop":{"X":740,"Y":8},"RightBottom":{"X":1047,"Y":192},"RightTop":{"X":1047,"Y":8}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Questão 091 (H8 | Enem 2016) Dificuldade 701,3","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":273},"LeftTop":{"X":101,"Y":230},"RightBottom":{"X":820,"Y":273},"RightTop":{"X":820,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"A usina de Itaipu é uma das maiores hidrelétricas do mundo em geração de energia. Com 20 unidades geradoras e 14 000 MW de potência total instalada, apresenta uma queda de 118,4 m e vazão nominal de 690 m$^{3}$/s por unidade geradora. O cálculo da potência teórica leva em conta a altura da massa de água represada pela barragem, a gravidade local (10 m/s$^{2}$) e a densidade da água (1 000 kg/m$^{3}$). A diferença entre a potência teórica e a instalada é a potência não aproveitada.","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":753},"LeftTop":{"X":97,"Y":301},"RightBottom":{"X":845,"Y":753},"RightTop":{"X":845,"Y":301}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"Disponível em: www.itaipu.gov.br. Acesso em: 11 maio 2013\n(adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":186,"Y":847},"LeftTop":{"X":186,"Y":781},"RightBottom":{"X":845,"Y":847},"RightTop":{"X":845,"Y":781}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"Qual é a potência, em MW, não aproveitada em cada unidade geradora de Itaipu?","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":958},"LeftTop":{"X":101,"Y":874},"RightBottom":{"