1751},"RightBottom":{"X":845,"Y":2383},"RightTop":{"X":845,"Y":1751}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":1001,"Y":657},"LeftTop":{"X":1001,"Y":235},"RightBottom":{"X":1595,"Y":657},"RightTop":{"X":1595,"Y":235}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"|A|B| C| A| |B|C| A| |A|16| B| C| A| |A|12| B| C| A| |B|5| A| |A|5| B| C| A|","Level":0,"Polygon":{"LeftBottom":{"X":1001,"Y":657},"LeftTop":{"X":1001,"Y":235},"RightBottom":{"X":1595,"Y":657},"RightTop":{"X":1595,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/ace122dc04dcedb3b9f5132e39fbf49a-image.png","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"Com base nos dados obtidos, o investidor adquiriu as moedas","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":761},"LeftTop":{"X":938,"Y":685},"RightBottom":{"X":1686,"Y":761},"RightTop":{"X":1686,"Y":685}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"A AeB. B AeC. ![](1335,785,1369,824)B C.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":827},"LeftTop":{"X":942,"Y":784},"RightBottom":{"X":1504,"Y":827},"RightTop":{"X":1504,"Y":784}},"InsetImageName":"","Elements":null,"ImagePath":"images/d9885fe03ffb402eff455e1e7de1b292-image.png","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"D BeD. E CeD.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":892},"LeftTop":{"X":942,"Y":849},"RightBottom":{"X":1310,"Y":892},"RightTop":{"X":1310,"Y":849}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"title","Text":"#  Questão 075 (H7 | Enem 2020) Dificuldade 595,8","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1011},"LeftTop":{"X":938,"Y":976},"RightBottom":{"X":1663,"Y":1011},"RightTop":{"X":1663,"Y":976}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"A Torre Eiffel, com seus 324 metros de altura, feita com treliças de ferro, pesava 7 300 toneladas quando terminou de ser construída em 1889. Um arquiteto resolve construir um protótipo dessa torre em escala 1:100, usando os mesmos materiais (cada dimensão linear em escala de 1:100 do monumento real). Considere que a torre real tenha uma massa $M_{torre}$ e exerça na fundação sobre a qual foi erguida uma pressão $P_{torre}$. O modelo construído pelo arquiteto terá uma massa $M_{modelo}$ e exercerá uma pressão $P_{modelo}$.","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1501},"LeftTop":{"X":938,"Y":1034},"RightBottom":{"X":1688,"Y":1501},"RightTop":{"X":1688,"Y":1034}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":1174,"Y":2016},"LeftTop":{"X":1174,"Y":1524},"RightBottom":{"X":1469,"Y":2016},"RightTop":{"X":1469,"Y":1524}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":1174,"Y":2016},"LeftTop":{"X":1174,"Y":1524},"RightBottom":{"X":1469,"Y":2016},"RightTop":{"X":1469,"Y":1524}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/390018bd60b2fa46e3b769dc16bb6498-image.png","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"Como a pressão exercida pela torre se compara com a pressão exercida pelo protótipo? Ou seja, qual é a razão entre as pressões $\\frac{(P_{\\text{torre}})}{(P_{\\text{modelo}})}$?","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":2228},"LeftTop":{"X":938,"Y":2054},"RightBottom":{"X":1686,"Y":2228},"RightTop":{"X":1686,"Y":2054}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"A $10^0$ B $10^1$ ![](1335,2258,1369,2