"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"As centrífugas são equipamentos utilizados em laboratórios, clínicas e indústrias. Seu funcionamento faz uso da aceleração centrífuga obtida pela rotação de um recipiente e que serve para a separação de sólidos em suspensão em líquidos ou de líquidos misturados entre si.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1074},"LeftTop":{"X":101,"Y":847},"RightBottom":{"X":845,"Y":1074},"RightTop":{"X":845,"Y":847}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"RODITI, I. Dicionário Houaiss de física. Rio de Janeiro: Objetiva, 2005\n(adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1157},"LeftTop":{"X":108,"Y":1097},"RightBottom":{"X":845,"Y":1157},"RightTop":{"X":845,"Y":1097}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Nesse aparelho, a separação das substâncias ocorre em função","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1256},"LeftTop":{"X":101,"Y":1183},"RightBottom":{"X":845,"Y":1256},"RightTop":{"X":845,"Y":1183}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"A das diferentes densidades.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1317},"LeftTop":{"X":102,"Y":1276},"RightBottom":{"X":542,"Y":1317},"RightTop":{"X":542,"Y":1276}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"B dos diferentes raios de rotação.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1380},"LeftTop":{"X":102,"Y":1339},"RightBottom":{"X":597,"Y":1380},"RightTop":{"X":597,"Y":1339}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"ⓒ das diferentes velocidades angulares.","Level":0,"Polygon":{"LeftBottom":{"X":