p":{"X":820,"Y":960}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Em 1962, um jingle (vinheta musical) criado por Heitor Carillo fez tanto sucesso que extrapolou as fronteiras do rádio e chegou à televisão ilustrado por um desenho animado. Nele, uma pessoa respondia ao fantasma que batia em sua porta, personificando o “frio”, que não o deixaria entrar, pois não abriria a porta e compraria lãs e cobertores para aquecer sua casa. Apesar de memorável, tal comercial televisivo continha incorreções a respeito de conceitos físicos relativos à calorimetria.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1488},"LeftTop":{"X":102,"Y":1029},"RightBottom":{"X":840,"Y":1488},"RightTop":{"X":840,"Y":1029}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"DUARTE, M. Jingle é a alma do negócio: livro revela os bastidores das músicas de propagandas. Disponível em: https://guiadoscuriosos.uol.com.br. Acesso em: 24 abr. 2019 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":193,"Y":1668},"LeftTop":{"X":193,"Y":1524},"RightBottom":{"X":840,"Y":1668},"RightTop":{"X":840,"Y":1524}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Para solucionar essas incorreções, deve-se associar à porta e aos cobertores, respectivamente, as funções de","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1824},"LeftTop":{"X":102,"Y":1695},"RightBottom":{"X":840,"Y":1824},"RightTop":{"X":840,"Y":1695}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"A Aquecer a casa e os corpos.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1900},"LeftTop":{"X":108,"Y":1860},"RightBottom":{"X":567,"Y":1900},"RightTop":{"X":567,"Y":1860}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"B Evitar a entrada do frio na casa e nos corpos.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1976},"LeftTop":{"X":108,"Y":1933},"RightBottom":{"X":808,"Y":1976},"RightTop":{"X":808,"Y":1933}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"ⓒ Minimizar a perda de calor pela casa e pelos corpos.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":2095},"LeftTop":{"X":108,"Y":2009},"RightBottom":{"X":856,"Y":2095},"RightTop":{"X":856,"Y":2009}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"D Diminuir a entrada do frio na casa e aquecer os corpos.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":2213},"LeftTop":{"X":108,"Y":2130},"RightBottom":{"X":856,"Y":2213},"RightTop":{"X":856,"Y":2130}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Aquecer a casa e reduzir a perda de calor pelos corpos.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":2332},"LeftTop":{"X":108,"Y":2244},"RightBottom":{"X":854,"Y":2332},"RightTop":{"X":854,"Y":2244}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"title","Text":"##  Questão 028 (H3 | Enem 2020) Dificuldade 547,5","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":273},"LeftTop":{"X":945,"Y":238},"RightBottom":{"X":1663,"Y":273},"RightTop":{"X":1663,"Y":238}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"Nos desenhos animados, com frequência se vê um personagem correndo na direção de um abismo, mas, ao invés de cair, ele continua andando no vazio e só quando percebe que não há nada sob seus pés é que ele para de andar e cai verticalmente. No entanto, para observar uma trajetória de queda num experimento real, pode-se lançar uma bolinha, com velocidade constante ($V_0$), sobre a superfície de uma mesa e verificar o seu movimento de queda até o chão.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":670},"LeftTop":{"X":940,"Y":296},"RightBottom":{"X":1681,"Y":670},"RightTop":{"X":1681,"Y":296}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"Qual figura melhor representa a trajetória de queda da bolinha?","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":768},"LeftTop":{"X":942,"Y":698},"RightBottom":{"X":1686,"Y":768},"RightTop":{"X":1686,"Y":698}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":2362},"LeftTop":{"X":940,"Y":791},"RightBottom":{"X":1386,"Y":2362},"RightTop":{"X":1386,"Y":791}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"graph TD     A[Mesa] --> B[A]     Solo --> C[Mesa]     Solo --> D[Mesa]          C --> E[Solo]     D --> F[Mesa]     Solo --> G[Mesa]     Solo --> H[Mesa]     Solo --> I[Solo]     H --> J[Mesa]     Solo --> K[Solo]","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":2362},"LeftTop":{"X":940,"Y":791},"RightBottom":{"X":1386,"Y":2362},"RightTop":{"X":1386,"Y":791}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/ba48900bd9596ee90d471f5c358a0f7f-image.png","group_id":-1,"group_type":""},{"Index":18,"Type":"footer","Text":"Competência 1 | Enem 360 – Versão Ciências da Natureza","Level":0,"Polygon":{"LeftBottom":{"X":527,"Y":2471},"LeftTop":{"X":527,"Y":2436},"RightBottom":{"X":1258,"Y":2471},"RightTop":{"X":1258,"Y":2436}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"footer","Text":"Página$^{34}$","Level":0,"Polygon":{"LeftBottom":{"X":1706,"Y":2390},"LeftTop":{"X":1706,"Y":2226},"RightBottom":{"X":1761,"Y":2390},"RightTop":{"X":1761,"Y":2226}},"InsetImageName":"","Elements":null,"ImagePath"