o de produtos tóxicos nas águas do Rio Doce, ocorridos em 2015, ainda têm consequências para os organismos que habitam o Parque Nacional Marinho de Abrolhos, localizado a mais de 1 000 quilômetros de distância. Esse desastre ambiental afetou o fitoplâncton, as esponjas, as algas macroscópicas, os peixes herbívoros e os golfinhos.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":640},"LeftTop":{"X":940,"Y":296},"RightBottom":{"X":1683,"Y":640},"RightTop":{"X":1683,"Y":296}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"FRAINER, G.; SICILIANO, S.; TAVARES, D. C. Franciscana calls for help: [...]. International Whaling Commission, Conference Paper, jun. 2016 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":748},"LeftTop":{"X":944,"Y":667},"RightBottom":{"X":1683,"Y":748},"RightTop":{"X":1683,"Y":667}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"Concentrações mais elevadas dos compostos citados são encontradas em","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":824},"LeftTop":{"X":944,"Y":756},"RightBottom":{"X":1679,"Y":824},"RightTop":{"X":1679,"Y":756}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"A esponjas.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":890},"LeftTop":{"X":947,"Y":857},"RightBottom":{"X":1142,"Y":890},"RightTop":{"X":1142,"Y":857}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"B golfinhos.","Level":0,"Polygon":{"LeftBottom":{"X":949,"Y":955},"LeftTop":{"X":949,"Y":920},"RightBottom":{"X":1142,"Y":955},"RightTop":{"X":1142,"Y":920}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"ⓒ fitoplâncton.","Level":0,"Polygon":{"LeftBottom":{"X":949,"Y":1016},"LeftTop":{"X":949,"Y"