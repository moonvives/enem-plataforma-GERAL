{"PageNumber":88,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Fredão","Level":0,"Polygon":{"LeftBottom":{"X":736,"Y":192},"LeftTop":{"X":736,"Y":16},"RightBottom":{"X":1044,"Y":192},"RightTop":{"X":1044,"Y":16}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Questão 169 (H17 | Enem 2018) Dificuldade 625,8","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":273},"LeftTop":{"X":102,"Y":235},"RightBottom":{"X":836,"Y":273},"RightTop":{"X":836,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"O processo de formação de novas espécies é lento e repleto de nuances e estágios intermediários, havendo uma diminuição da viabilidade entre cruzamentos. Assim, plantas originalmente de uma mesma espécie que não cruzam mais entre si podem ser consideradas como uma espécie se diferenciando. Um pesquisador realizou cruzamentos entre nove populações — denominadas de acordo com a localização onde são encontradas — de uma espécie de orquídea (Epidendrum denticulatum). No diagrama estão os resultados dos cruzamentos entre as populações. Considere que o doador fornece o pólen para o receptor.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":536},"LeftTop":{"X":99,"Y":294},"RightBottom":{"X":1685,"Y":536},"RightTop":{"X":1685,"Y":294}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":384,"Y":1562},"LeftTop":{"X":384,"Y":576},"RightBottom":{"X":1386,"Y":1562},"RightTop":{"X":1386,"Y":576}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"graph TD     A[IRAPINA] --> B[ITIRAPINA] --> C[CRUZAMENTOS]          B --> BA[PÃO DE ACÚCAR]     B --> BB[PETI]          C --> CA[PETI]          D --> DA[ALCOBACA]          D --> DB[BERTIOGA]     D --> DC[OLIVENCA]          D --> DA[MARAMBAIA]","Level":0,"Polygon":{"LeftBottom":{"X":384,"Y":1562},"LeftTop":{"X":384,"Y":576},"RightBottom":{"X":1386,"Y":1562},"RightTop":{"X":1386,"Y":576}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/88f0d4b330efcbdd7885b69139b1774d-image.png","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"DOADOR → RECEPTOR - Polinização induzida bem-sucedida","Level":0,"Polygon":{"LeftBottom":{"X":424,"Y":1607},"LeftTop":{"X":424,"Y":1569},"RightBottom":{"X":1283,"Y":1607},"RightTop":{"X":1283,"Y":1569}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"DOADOR ...... RECEPTOR - Polinização induzida inviável ou nula","Level":0,"Polygon":{"LeftBottom":{"X":427,"Y":1658},"LeftTop":{"X":427,"Y":1625},"RightBottom":{"X":1308,"Y":1658},"RightTop":{"X":1308,"Y":1625}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Mata Atlântica ![](704,1670,768,1713) Cerrado","Level":0,"Polygon":{"LeftBottom":{"X":426,"Y":1716},"LeftTop":{"X":426,"Y":1668},"RightBottom":{"X":876,"Y":1716},"RightTop":{"X":876,"Y":1668}},"InsetImageName":"","Elements":null,"ImagePath":"images/84070393df3cd3663d0619014e8b4721-image.png","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"FIORAVANTI, C. Os primeiros passos de novas espécies: plantas e animais se diferenciam por meio de mecanismos surpreendentes. Pesquisa Fapesp, out. 2013 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":131,"Y":1809},"LeftTop":{"X":131,"Y":1743},"RightBottom":{"X":1685,"Y":1809},"RightTop":{"X":1685,"Y":1743}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Em populações de quais localidades se observa um processo de especiação evidente?","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":