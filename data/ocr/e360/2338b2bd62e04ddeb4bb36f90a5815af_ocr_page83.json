{"PageNumber":83,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Fredov","Level":0,"Polygon":{"LeftBottom":{"X":740,"Y":198},"LeftTop":{"X":740,"Y":16},"RightBottom":{"X":1047,"Y":198},"RightTop":{"X":1047,"Y":16}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Questão 162 (H16 | Enem 2019) Dificuldade 670,5","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":273},"LeftTop":{"X":104,"Y":235},"RightBottom":{"X":838,"Y":273},"RightTop":{"X":838,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Durante sua evolução, as plantas apresentaram grande diversidade de características, as quais permitiram sua sobrevivência em diferentes ambientes. Na imagem, cinco dessas características estão indicadas por números.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":372},"LeftTop":{"X":99,"Y":291},"RightBottom":{"X":1683,"Y":372},"RightTop":{"X":1683,"Y":291}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":117,"Y":1082},"LeftTop":{"X":117,"Y":384},"RightBottom":{"X":1670,"Y":1082},"RightTop":{"X":1670,"Y":384}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"|Anóceros| 1|  |Musgos| 2|  |Licófitas (licopódios, Isoetes, Selaginella)| |Pteridófitas (samambaias, cavalinhas, Psilotum)| |Gimnospermas| 5|  |Angiospermas| 10|","Level":0,"Polygon":{"LeftBottom":{"X":117,"Y":1082},"LeftTop":{"X":117,"Y":384},"RightBottom":{"X":1670,"Y":1082},"RightTop":{"X":1670,"Y":384}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/1319500e80551a87fd387d1737d7e529-image.png","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"CAMPBELL, N. et al. Biologia. São Pau