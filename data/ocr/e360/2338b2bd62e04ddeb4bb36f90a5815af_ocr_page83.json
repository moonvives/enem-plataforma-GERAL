nsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"title","Text":"#  Questão 163 (H16 | Enem 2021) Dificuldade 676,5","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1488},"LeftTop":{"X":101,"Y":1445},"RightBottom":{"X":838,"Y":1488},"RightTop":{"X":838,"Y":1445}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"Entre 2014 e 2016, as regiões central e oeste da África sofreram uma grave epidemia de febre hemorrágica causada pelo vírus ebola, que se manifesta em até 21 dias após a infecção e cuja taxa de letalidade (enfermos que vão a óbito) pode chegar a 90%. Em regiões de clima tropical e subtropical, um outro vírus também pode causar febre hemorrágica: o vírus da dengue, que, embora tenha período de incubação menor (até 10 dias), apresenta taxa de letalidade abaixo de 1%.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1700},"LeftTop":{"X":101,"Y":1509},"RightBottom":{"X":1679,"Y":1700},"RightTop":{"X":1679,"Y":1509}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Disponível em: www.who.int. Acesso em: 1 fev. 2017 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":981,"Y":1748},"LeftTop":{"X":981,"Y":1713},"RightBottom":{"X":1679,"Y":1748},"RightTop":{"X":1679,"Y":1713}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"Segundo as informações do texto e aplicando princípios de evolução biológica às relações do tipo patógeno-hospedeiro, qual dos dois vírus infecta seres humanos há mais tempo?","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1842},"LeftTop":{"X":101,"Y":1766},"RightBottom":{"X":1683,"Y":1842},"RightTop":{"X":1683,"Y":1766}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"A Ebola, pois o maior período de incubação reflete duração mais longa do processo de coevolução patógenohospedeiro.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1940},"LeftTop":{"X":104,"Y":1867},"RightBottom":{"X":1667,"Y":1940},"RightTop":{"X":1667,"Y":1867}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"Ⓑ Dengue, pois o menor período de incubação reflete duração mais longa do processo de coevolução patógenohospedeiro.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2034},"LeftTop":{"X":104,"Y":1961},"RightBottom":{"X":1669,"Y":2034},"RightTop":{"X":1669,"Y":1961}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"Ebola, cuja alta letalidade indica maior eficiência do vírus em parasitar seus hospedeiros, estabelecida ao longo de sua evolução.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2132},"LeftTop":{"X":104,"Y":2057},"RightBottom":{"X":1665,"Y":2132},"RightTop":{"X":1665,"Y":2057}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"Ebola, cujos surtos epidêmicos concentram-se no continente africano, reconhecido como berço da origem evolutiva dos seres humanos.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2231},"LeftTop":{"X":104,"Y":2155},"RightBottom":{"X":1669,"Y":2231},"RightTop":{"X":1669,"Y":2155}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"Dengue, cuja baixa letalidade indica maior eficiência do vírus em parasitar seus hospedeiros, estabelecida ao longo da coevolução patógeno-hospedeiro.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2329},"LeftTop":{"X":104,"Y":2251},"RightBottom":{"X":1665,"Y":2329},"RightTop":{"X":1665,"Y":2251}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"footer","Text":"Página 92","Level":0,"Polygon":{"LeftBottom":{"X":1708,