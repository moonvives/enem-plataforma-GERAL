m":{"X":218,"Y":2254},"RightTop":{"X":218,"Y":2213}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"E 13,1.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2337},"LeftTop":{"X":102,"Y":2297},"RightBottom":{"X":238,"Y":2337},"RightTop":{"X":238,"Y":2297}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"title","Text":"#  Questão 127 (H12 | Enem 2020) Dificuldade 701,0","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":271},"LeftTop":{"X":940,"Y":230},"RightBottom":{"X":1670,"Y":271},"RightTop":{"X":1670,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"O crescimento da frota de veículos em circulação no mundo tem levado à busca e desenvolvimento de tecnologias que permitam minimizar emissões de poluentes atmosféricos. O uso de veículos elétricos é uma das propostas mais propagandeadas por serem de emissão zero. Podemos comparar a emissão de carbono na forma de CO₂ (massa molar igual a 44 g mol⁻$^{1}$) para os dois tipos de carros (a combustão e elétrico). Considere que os veículos tradicionais a combustão, movidos a etanol (massa molar igual a 46 g mol⁻$^{1}$), emitem uma média de 2,6 mol de CO₂ por quilômetro rodado, e os elétricos emitem o equivalente a 0,45 mol de CO₂ por quilômetro rodado (considerando as emissões na geração e transmissão da eletricidade). A reação de combustão do etanol pode ser representada pela equação química:","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":1263},"LeftTop":{"X":936,"Y":306},"RightBottom":{"X":1679,"Y":1263},"RightTop":{"X":1679,"Y":306}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"formula","Text":"$$C_2H_5OH(I) + 3 O_2(g) \\rightarrow 2 CO_2(g) + 3 H_2O(g)$$","Level":0,"Polygon":{"LeftBottom":{"X":967,"Y":1347},"LeftTop":{"X":967,"Y":1299},"RightBottom":{"X":1653,"Y":1347},"RightTop":{"X":1653,"Y":1299}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"Foram analisadas as emissões de CO₂ envolvidas em dois veículos, um movido a etanol e outro elétrico, em um mesmo trajeto de 1 000 km.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":1549},"LeftTop":{"X":940,"Y":1395},"RightBottom":{"X":1679,"Y":1549},"RightTop":{"X":1679,"Y":1395}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"CHIARADIA, C. A. Estudo da viabilidade da implantação de frotas de veículos elétricos e híbridos elétricos no atual cenário econômico, político, energético e ambiental brasileiro.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1695},"LeftTop":{"X":944,"Y":1584},"RightBottom":{"X":1679,"Y":1695},"RightTop":{"X":1679,"Y":1584}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"Guaratinguetá: Unesp, 2015 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":1244,"Y":1736},"LeftTop":{"X":1244,"Y":1706},"RightBottom":{"X":1676,"Y":1736},"RightTop":{"X":1676,"Y":1706}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"A quantidade equivalente de etanol economizada, em quilograma, com o uso do veículo elétrico nesse trajeto, é mais próxima de","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":1913},"LeftTop":{"X":936,"Y":1769},"RightBottom":{"X":1679,"Y":1913},"RightTop":{"X":1679,"Y":1769}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"A 50.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1991},"LeftTop":{"X":944,"Y":1953},"RightBottom":{"X":1049,"Y":1991},"RightTop":{"X":1049,"Y":1953}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"B 6