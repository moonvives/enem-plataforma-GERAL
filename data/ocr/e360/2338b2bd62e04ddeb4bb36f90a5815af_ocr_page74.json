 a dupla hélice precisa ser totalmente desnaturada (desenrolada) pelo aumento da temperatura, quando são desfeitas as ligações hidrogênio entre as diferentes bases nitrogenadas.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1594},"LeftTop":{"X":101,"Y":1137},"RightBottom":{"X":843,"Y":1594},"RightTop":{"X":843,"Y":1137}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"Qual dos segmentos de DNA será o primeiro a desnaturar totalmente durante o aumento da temperatura na reação de PCR?","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1721},"LeftTop":{"X":102,"Y":1612},"RightBottom":{"X":843,"Y":1721},"RightTop":{"X":843,"Y":1612}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"A ![](171,1734,455,1850)","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1844},"LeftTop":{"X":102,"Y":1751},"RightBottom":{"X":363,"Y":1844},"RightTop":{"X":363,"Y":1751}},"InsetImageName":"","Elements":null,"ImagePath":"images/9cde7bd29b7f34b0526a30e73d4a8752-image.png","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"B ![](171,1867,459,1979)","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1973},"LeftTop":{"X":104,"Y":1872},"RightBottom":{"X":363,"Y":1973},"RightTop":{"X":363,"Y":1872}},"InsetImageName":"","Elements":null,"ImagePath":"images/dc81382ae1c61278b67fb5e959da90a3-image.png","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"ⓒ ![](171,1992,455,2107)","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":2095},"LeftTop":{"X":108,"Y":2001},"RightBottom":{"X":359,"Y":2095},"RightTop":{"X":359,"Y":2001}},"InsetImageName":"","Elements":null,"ImagePath":"images/7b3b96dbbe4c48806341c6aba9479770-image.png","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"Ⓓ ![](167,2120,455,2236)","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":2226},"LeftTop":{"X":108,"Y":2127},"RightBottom":{"X":365,"Y":2226},"R