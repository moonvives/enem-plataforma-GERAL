{"PageNumber":74,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Redão","Level":0,"Polygon":{"LeftBottom":{"X":747,"Y":195},"LeftTop":{"X":747,"Y":13},"RightBottom":{"X":1054,"Y":195},"RightTop":{"X":1054,"Y":13}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Questão 139 (H14 | Enem 2020) Dificuldade 562,4","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":271},"LeftTop":{"X":102,"Y":230},"RightBottom":{"X":840,"Y":271},"RightTop":{"X":840,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Grupos de proteção ao meio ambiente conseguem resgatar muitas aves aquáticas vítimas de vazamentos de petróleo. Essas aves são lavadas com água e detergente neutro para a retirada completa do óleo de seu corpo e, posteriormente, são aquecidas, medicadas, desintoxicadas e alimentadas. Mesmo após esses cuidados, o retorno ao ambiente não pode ser imediato, pois elas precisam recuperar a capacidade de flutuação.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":607},"LeftTop":{"X":99,"Y":291},"RightBottom":{"X":843,"Y":607},"RightTop":{"X":843,"Y":291}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"Para flutuar, essas aves precisam","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":662},"LeftTop":{"X":101,"Y":624},"RightBottom":{"X":585,"Y":662},"RightTop":{"X":585,"Y":624}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"A recuperar o tônus muscular.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":723},"LeftTop":{"X":104,"Y":685},"RightBottom":{"X":563,"Y":723},"RightTop":{"X":563,"Y":685}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Tex