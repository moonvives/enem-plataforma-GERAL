5,"Y":1511},"RightBottom":{"X":1679,"Y":1594},"RightTop":{"X":1679,"Y":1511}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":34,"Type":"paragraph","Text":"Como corrigir essa distorção? Bom, farei aqui uma proposta baseada na análise dos microdados dos últimos 10 anos, no qual a dificuldade média foi de 648,3 em ciências da natureza, além de um desvio padrão de 80,8. Usando esses valores, em conjunto com os dados da tabela do referido livro e uma aproximação para efeito de simplificação das análises, sugiro que você, aluno, considere como:","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":1951},"LeftTop":{"X":940,"Y":1622},"RightBottom":{"X":1681,"Y":1951},"RightTop":{"X":1681,"Y":1622}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":35,"Type":"paragraph","Text":"● Muito fáceis: dificuldade inferior a 560,0;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":2016},"LeftTop":{"X":995,"Y":1981},"RightBottom":{"X":1645,"Y":2016},"RightTop":{"X":1645,"Y":1981}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":36,"Type":"paragraph","Text":"● Fáceis: dificuldade de 560,0 a 619,9;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":2059},"LeftTop":{"X":995,"Y":2024},"RightBottom":{"X":1576,"Y":2059},"RightTop":{"X":1576,"Y":2024}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":37,"Type":"paragraph","Text":"● Medianos: dificuldade de 620,0 a 679,9;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":2105},"LeftTop":{"X":995,"Y":2069},"RightBottom":{"X":1624,"Y":2105},"RightTop":{"X":1624,"Y":2069}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":38,"Type":"paragraph","Text":"● Difíceis: dificuldade de 680,0 a 739,9;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":2145},"LeftTop":{"X":995,"Y":2110},"RightBottom":{"X":1590,"Y":2145},"RightTop":{"X":1590,"Y":2110}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":39,"Type":"paragraph","Text":"● Muito difíceis: dificuldade superior a 740,0.","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":2191},"LeftTop":{"X":995,"Y":2153},"RightBottom":{"X":1679,"Y":2191},"RightTop":{"X":1679,"Y":2153}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":40,"Type":"paragraph","Text":"Assim, teremos, neste material, 32 itens muito fáceis, 73 fáceis, 117 medianos, 58 difíceis e 28 muito difíceis, o que considero bem próximo ao esperado de uma avaliação educacional como o ENEM!","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":2383},"LeftTop":{"X":940,"Y":2218},"RightBottom":{"X":1681,"Y":2383},"RightTop":{"X":1681,"Y":2218}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":41,"Type":"footer","Text":"Página 18","Level":0,"Polygon":{"LeftBottom":{"X":1704,"Y":2388},"LeftTop":{"X":1704,"Y":2233},"RightBottom":{"X":1763,"Y":2388},"RightTop":{"X":1763,"Y":2233}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":42,"Type":"footer","Text":"B de Dificuldade | Enem 360 – Versão Ciências da Natureza","Level":0,"Polygon":{"LeftBottom":{"X":517,"Y":2466},"LeftTop":{"X":517,"Y":2431},"RightBottom":{"X":1263,"Y":2466},"RightTop":{"X":1263,"Y":2431}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}