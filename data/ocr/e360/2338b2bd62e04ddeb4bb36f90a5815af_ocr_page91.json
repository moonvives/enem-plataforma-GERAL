 e comprimentos de alguns dos fios construídos (respectivamente com as mesmas unidades de medida). Considere que a resistividade mantém-se constante para todas as geometrias (uma aproximação confirmada pelo estudo).","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2029},"LeftTop":{"X":102,"Y":1673},"RightBottom":{"X":840,"Y":2029},"RightTop":{"X":840,"Y":1673}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"table","Text":"<table><tr><td></td><td>Área</td><td>Comprimento</td><td>Resistência elétrica</td></tr><tr><td>Fio 1</td><td>9</td><td>312</td><td>R1</td></tr><tr><td>Fio 2</td><td>4</td><td>47</td><td>R2</td></tr><tr><td>Fio 3</td><td>2</td><td>54</td><td>R3</td></tr><tr><td>Fio 4</td><td>1</td><td>106</td><td>R4</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":147,"Y":2309},"LeftTop":{"X":147,"Y":2054},"RightBottom":{"X":802,"Y":2309},"RightTop":{"X":802,"Y":2054}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"WEBER, S. B. et al. Ohm's Law Survives to the Atomic Scale. Science, n. 335, jan. 2012 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":179,"Y":2385},"LeftTop":{"X":179,"Y":2329},"RightBottom":{"X":840,"Y":2385},"RightTop":{"X":840,"Y":2329}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"As resistências elétricas dos fios, em ordem crescente, são","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":304},"LeftTop":{"X":945,"Y":235},"RightBottom":{"X":1681,"Y":304},"RightTop":{"X":1681,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"A R1<R2<R3<R4.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":369},"LeftTop":{"X":947,"Y":334},"RightBottom":{"X":1288,"Y":369},"RightTop":{"X":1288,"Y":334}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"Ⓑ R2 < R1 < R3 < R4.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":435},"LeftTop":{"X":947,"Y":400},"RightBottom":{"X":1295,"Y":435},"RightTop":{"X":1295,"Y":400}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"© R2 < R3 < R1 < R4.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":498},"LeftTop":{"X":947,"Y":465},"RightBottom":{"X":1292,"Y":498},"RightTop":{"X":1292,"Y":465}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"Ⓓ R4 < R1 < R3 < R2.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":559},"LeftTop":{"X":947,"Y":526},"RightBottom":{"X":1292,"Y":559},"RightTop":{"X":1292,"Y":526}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"E R4 < R3 < R2 < R1.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":624},"LeftTop":{"X":947,"Y":589},"RightBottom":{"X":1288,"Y":624},"RightTop":{"X":1288,"Y":589}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"title","Text":"##  Questão 175 (H17 | Enem 2019) Dificuldade 667,3","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":743},"LeftTop":{"X":947,"Y":708},"RightBottom":{"X":1676,"Y":743},"RightTop":{"X":1676,"Y":708}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"Em 1808, Dalton publicou o seu famoso livro intitulado Um novo sistema de filosofia química (do original A New System of Chemical Philosophy), no qual continha os cinco postulados que serviam como alicerce da primeira teoria atômica da matéria fundamentada no método científico. Esses postulados são numerados a seguir:","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1024},"LeftTop":{"X":945,"Y":766},"RightBottom":{"X":1681,"Y":1024},"RightTop":{"X":1681,"Y":766}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"1. A matéria é constituída de átomos indivíveis.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":1079},"LeftTop":{"X":947,"Y":1049},"RightBottom":{"X":1629,"Y":1079},"RightTop":{"X":1629,"Y":1049}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"2. Todos os átomos de um dado elemento químico são idênticos em massa e em todas as outras propriedades.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1216},"LeftTop":{"X":945,"Y":1107},"RightBottom":{"X":1681,"Y":1216},"RightTop":{"X":1681,"Y":1107}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"3. Diferentes elementos químicos têm diferentes tipos de átomos; em particular, seus átomos têm diferentes massas.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1344},"LeftTop":{"X":945,"Y":1241},"RightBottom":{"X":1679,"Y":1344},"RightTop":{"X":1679,"Y":1241}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"4. Os átomos são indestrutíveis e nas reações químicas mantêm suas identidades.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1443},"LeftTop":{"X":945,"Y":1372},"RightBottom":{"X":1679,"Y":1443},"RightTop":{"X":1679,"Y":1372}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"5. Átomos de elementos combinam com átomos de outros elementos em proporções de números inteiros pequenos para formar compostos.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1579},"LeftTop":{"X":945,"Y":1466},"RightBottom":{"X":1679,"Y":1579},"RightTop":{"X":1679,"Y":1466}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"paragraph","Text":"Após o modelo de Dalton, outros modelos baseados em outros dados experimentais evidenciaram, entre outras coisas, a natureza elétrica da matéria, a composição e organização do átomo e a quantização da energia no modelo atômico.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1784},"LeftTop":{"X":945,"Y":1605},"RightBottom":{"X":1681,"Y":1784},"RightTop":{"X":1681,"Y":1605}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"paragraph","Text":"OXTOBY, D. W.; GILLIS, H. P.; BUTLER, L. J. Principles of Modern Chemistry. Boston: Cengage Learning, 2012 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":976,"Y":1862},"LeftTop":{"X":976,"Y":1804},"RightBottom":{"X":1681,"Y":1862},"RightTop":{"X":1681,"Y":1804}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":27,"Type":"paragraph","Text":"Com base no modelo atual que descreve o átomo, qual dos postulados de Dalton ainda é considerado correto?","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1991},"LeftTop":{"X":945,"Y":1887},"RightBottom":{"X":1681,"Y":1991},"RightTop":{"X":1681,"Y":1887}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":28,"Type":"paragraph","Text":"A 1","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":2057},"LeftTop":{"X":947,"Y":2021},"RightBottom":{"X":1024,"Y":2057},"RightTop":{"X":1024,"Y":2021}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":29,"Type":"paragraph","Text":"B 2","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":2117},"LeftTop":{"X":945,"Y":2087},"RightBottom":{"X":1024,"Y":2117},"RightTop":{"X":1024,"Y":2087}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":30,"Type":"paragraph","Text":"© 3","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":2183},"LeftTop":{"X":945,"Y":2148},"RightBottom":{"X":1024,"Y":2183},"RightTop":{"X":1024,"Y":2148}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":31,"Type":"paragraph","Text