{"PageNumber":91,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Fredão","Level":0,"Polygon":{"LeftBottom":{"X":745,"Y":192},"LeftTop":{"X":745,"Y":8},"RightBottom":{"X":1049,"Y":192},"RightTop":{"X":1049,"Y":8}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Questão 173 (H17 | Enem 2017) Dificuldade 665,6","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":268},"LeftTop":{"X":104,"Y":235},"RightBottom":{"X":838,"Y":268},"RightTop":{"X":838,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Dispositivos eletrônicos que utilizam materiais de baixo custo, como polímeros semicondutores, têm sido desenvolvidos para monitorar a concentração de amônia (gás tóxico e incolor) em granjas avícolas. A polianilina é um polímero semicondutor que tem o valor de sua resistência elétrica nominal quadruplicado quando exposta a altas concentrações de amônia. Na ausência de amônia, a polianilina se comporta como um resistor ôhmico e a sua resposta elétrica é mostrada no gráfico.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":655},"LeftTop":{"X":104,"Y":294},"RightBottom":{"X":840,"Y":655},"RightTop":{"X":840,"Y":294}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":117,"Y":1178},"LeftTop":{"X":117,"Y":685},"RightBottom":{"X":827,"Y":1178},"RightTop":{"X":827,"Y":685}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"|Corrente|79%| |:---:|100%|","Level":0,"Polygon":{"LeftBottom":{"X":117,"Y":1178},"LeftTop":{"X":117,"Y":685},"RightBottom":{"X":827,"Y":1178},"RightTop":{"X":827,"Y":685}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/34afceaf22e7ae0d10490427d30cd