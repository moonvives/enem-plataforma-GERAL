{"PageNumber":43,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Fredão","Level":0,"Polygon":{"LeftBottom":{"X":727,"Y":192},"LeftTop":{"X":727,"Y":8},"RightBottom":{"X":1044,"Y":192},"RightTop":{"X":1044,"Y":8}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Questão 065 (H6 | Enem 2021) Dificuldade 640,7","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":268},"LeftTop":{"X":102,"Y":233},"RightBottom":{"X":818,"Y":268},"RightTop":{"X":818,"Y":233}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"O alcoolômetro Gay Lussac é um instrumento destinado a medir o teor de álcool, em porcentagem de volume (v/v), de soluções de água e álcool na faixa de 0 °GL a 100 °GL, com divisões de 0,1 °GL. A concepção do alcoolômetro se baseia no princípio de flutuabilidade de Arquimedes, semelhante ao funcionamento de um densímetro. A escala do instrumento é aferida a 20 °C, sendo necessária a correção da medida, caso a temperatura da solução não esteja na temperatura de aferição. É apresentada parte da tabela de correção de um alcoolômetro, com a temperatura","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":728},"LeftTop":{"X":99,"Y":294},"RightBottom":{"X":843,"Y":728},"RightTop":{"X":843,"Y":294}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"title","Text":"##  Tabela de correção do alcoolômetro com temperatura 20 °C","Level":0,"Polygon":{"LeftBottom":{"X":159,"Y":839},"LeftTop":{"X":159,"Y":763},"RightBottom":{"X":783,"Y":839},"RightTop":{"X":783,"Y":763}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"table","Text":"<table><tr><td rowspan=\"2\">°GL</td><td colspan=\"6\">Leitura da temperatura (°C)</td></tr><tr><td>20</td><td>21</td><td>22</td><