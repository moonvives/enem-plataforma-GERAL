Bottom":{"X":947,"Y":561},"LeftTop":{"X":947,"Y":475},"RightBottom":{"X":1681,"Y":561},"RightTop":{"X":1681,"Y":475}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"ABNT. NBR 7500: identificação para o transporte terrestre, manuseio, movimentação e armazenamento de produtos. Rio de Janeiro, 2004 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":985,"Y":665},"LeftTop":{"X":985,"Y":581},"RightBottom":{"X":1679,"Y":665},"RightTop":{"X":1679,"Y":581}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"Considerando a identificação apresentada no caminhão, o código 1005 corresponde à substância","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":763},"LeftTop":{"X":945,"Y":690},"RightBottom":{"X":1679,"Y":763},"RightTop":{"X":1679,"Y":690}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"Aeteno (C2H4).","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":829},"LeftTop":{"X":947,"Y":789},"RightBottom":{"X":1194,"Y":829},"RightTop":{"X":1194,"Y":789}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"B nitrogênio ($N_2$).","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":892},"LeftTop":{"X":947,"Y":852},"RightBottom":{"X":1220,"Y":892},"RightTop":{"X":1220,"Y":852}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"© amônia ($NH_3$).","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":955},"LeftTop":{"X":947,"Y":915},"RightBottom":{"X":1208,"Y":955},"RightTop":{"X":1208,"Y":915}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"D propano ($C_3H_8$).","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":1018},"LeftTop":{"X":947,"Y":978},"RightBottom":{"X":1229,"Y":1018},"RightTop":{"X":1229,"Y":978}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"paragraph","Text":"E dióxido de carbono ($CO_2$).","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":1082},"LeftTop":{"X":947,"Y":1041},"RightBottom":{"X":1374,"Y":1082},"RightTop":{"X":1374,"Y":1041}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"title","Text":"#  Questão 067 (H6 | Enem 2020) Dificuldade 673,0","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1198},"LeftTop":{"X":945,"Y":1162},"RightBottom":{"X":1658,"Y":1198},"RightTop":{"X":1658,"Y":1162}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":27,"Type":"paragraph","Text":"Mesmo para peixes de aquário, como o peixe arcoíris, a temperatura da água fora da faixa ideal (26 °C a 28 °C), bem como sua variação brusca, pode afetar a saúde do animal. Para manter a temperatura da água dentro do aquário na média desejada, utilizam-se dispositivos de aquecimento com termostato. Por exemplo, para um aquário de 50 L, pode-se utilizar um sistema de aquecimento de 50 W otimizado para suprir sua taxa de resfriamento. Essa taxa pode ser considerada praticamente constante, já que a temperatura externa ao aquário é mantida pelas estufas.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1723},"LeftTop":{"X":944,"Y":1226},"RightBottom":{"X":1683,"Y":1723},"RightTop":{"X":1683,"Y":1226}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":28,"Type":"paragraph","Text":"Utilize para a água o calor específico 4,0 kJ kg$^{-1}$ K$^{-1}$ e a densidade 1 kg L$^{-1}$.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1842},"LeftTop":{"X":945,"Y":1754},"RightBottom":{"X":1679,"Y":1842},"RightTop":{"X":1679,"Y":1754}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":29,"Type":"paragraph","Text":"Se o sistema de aquecimento for desligado por 1 h, qual o valor mais próximo para a redução da temperatura da água do aquário?","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1996},"LeftTop":{"X":945,"Y":1875},"RightBottom":{"X":1681,"Y":1996},"RightTop":{"X":1681,"Y":1875}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":30,"Type":"paragraph","Text":"A 4,0°C","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":2064},"LeftTop":{"X":947,"Y":2026},"RightBottom":{"X":1101,"Y":2064},"RightTop":{"X":1101,"Y":2026}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":31,"Type":"paragraph","Text":"Ⓑ 3,6°C","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":2132},"LeftTop":{"X":947,"Y":2097},"RightBottom":{"X":1099,"Y":2132},"RightTop":{"X":1099,"Y":2097}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":32,"Type":"paragraph","Text":"© 0,9℃","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":2201},"LeftTop":{"X":947,"Y":2165},"RightBottom":{"X":1099,"Y":2201},"RightTop":{"X":1099,"Y":2165}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":33,"Type":"paragraph","Text":"D 0,6℃","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":2271},"LeftTop":{"X":947,"Y":2233},"RightBottom":{"X":1097,"Y":2271},"RightTop":{"X":1097,"Y":2233}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":34,"Type":"paragraph","Text":"E 0,3°C","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":2340},"LeftTop":{"X":947,"Y":2304},"RightBottom":{"X":1099,"Y":2340},"RightTop":{"X":1099,"Y":2304}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":35,"Type":"footer","Text":"Página 52","Level":0,"Polygon":{"LeftBottom":{"X":1708,"Y":2383},"LeftTop":{"X":1708,"Y":2231},"RightBottom":{"X":1763,"Y":2383},"RightTop":{"X":1763,"Y":2231}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":36,"Ty