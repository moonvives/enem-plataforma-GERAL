54,"Y":1410},"RightTop":{"X":854,"Y":1370}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"Ⓓ aumento da concentração de alcool durante a medida.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1503},"LeftTop":{"X":104,"Y":1433},"RightBottom":{"X":854,"Y":1503},"RightTop":{"X":854,"Y":1433}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"E alteração das propriedades químicas da mistura alcool e água.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1605},"LeftTop":{"X":104,"Y":1529},"RightBottom":{"X":854,"Y":1605},"RightTop":{"X":854,"Y":1529}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"title","Text":"##  Questão 066 (H6 | Enem 2018) Dificuldade 646,1","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1726},"LeftTop":{"X":102,"Y":1688},"RightBottom":{"X":817,"Y":1726},"RightTop":{"X":817,"Y":1688}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"A identificação de riscos de produtos perigosos para o transporte rodoviário é obrigatória e realizada por meio da sinalização composta por um painel de segurança, de cor alaranjada, e um rótulo de risco. As informações inseridas no painel de segurança e no rótulo de risco, conforme determina a legislação, permitem que se identifique o produto transportado e os perigos a ele associados.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":2034},"LeftTop":{"X":99,"Y":1748},"RightBottom":{"X":843,"Y":2034},"RightTop":{"X":843,"Y":1748}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"A sinalização mostrada identifica uma substância que está sendo transportada em um caminhão.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":2132},"LeftTop":{"X":99,"Y":2057},"RightBottom":{"X":840,"Y":2132},"Ri