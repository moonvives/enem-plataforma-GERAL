oup_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"Três lâmpadas idênticas foram ligadas no circuito esquematizado. A bateria apresenta resistência interna desprezível, e os fios possuem resistência nula. Um técnico fez uma análise do circuito para prever a corrente elétrica nos pontos: A, B, C, D e E; e rotulou essas correntes de $l_A, l_B, l_C, l_D$ e $l_E$, respectivamente.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2304},"LeftTop":{"X":102,"Y":2016},"RightBottom":{"X":843,"Y":2304},"RightTop":{"X":843,"Y":2016}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":1170,"Y":776},"LeftTop":{"X":1170,"Y":240},"RightBottom":{"X":1453,"Y":776},"RightTop":{"X":1453,"Y":240}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":1170,"Y":776},"LeftTop":{"X":1170,"Y":240},"RightBottom":{"X":1453,"Y":776},"RightTop":{"X":1453,"Y":240}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/50258364fceb9a770d9fc6f620923e42-image.png","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"O técnico concluiu que as correntes que apresentam o mesmo valor são","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":885},"LeftTop":{"X":944,"Y":809},"RightBottom":{"X":1683,"Y":885},"RightTop":{"X":1683,"Y":809}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"formula","Text":"A $l_A = l_E e l_C = l_D$.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":960},"LeftTop":{"X":947,"Y":920},"RightBottom":{"X":1215,"Y":960},"RightTop":{"X":1215,"Y":920}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"formula","Text":"B $I_A = I_B = I_E$ e $I_C = I_D$.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":1026},"LeftTop":{"X":947,"Y":988},"RightBottom":