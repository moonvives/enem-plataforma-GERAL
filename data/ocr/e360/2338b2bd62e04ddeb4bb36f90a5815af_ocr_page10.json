tom":{"X":1686,"Y":1092},"RightTop":{"X":1686,"Y":842}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"É justamente essa transformação do parâmetro B divulgado nos microdados que utilizaremos neste material! Assim, um parâmetro B igual a 2,137, por exemplo, refletirá em um item com dificuldade igual a 500 + 100*2,137 = 713,7.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":1332},"LeftTop":{"X":940,"Y":1114},"RightBottom":{"X":1686,"Y":1332},"RightTop":{"X":1686,"Y":1114}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"Na mesma figura, um participante X que tenha uma proficiência calculada com valor próximo a 600 tem aproximadamente 90% de chance de acertar o item. Naturalmente, o participante pode errar o item. Mas, o mais coerente, é que ele o acerte. Por esse motivo, a coerência das respostas é tão importante na TRI: por mais que um aluno acerte 44 dos 45 itens da matemática, se ele tiver errado um item fácil, para o qual a CCI indicaria uma chance de acerto próxima a 100%, a sua nota pode ser reduzida quando comparada à de um outro aluno que acertou 44 dos 45 itens, mas errando o item mais difícil da prova, para o qual a CCI indicaria uma chance de acerto, por exemplo, inferior a 50%.","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":1940},"LeftTop":{"X":936,"Y":1357},"RightBottom":{"X":1686,"Y":1940},"RightTop":{"X":1686,"Y":1357}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Caso queira se aprofundar um pouco mais na TRI, deixo abaixo um QR Code que leva ao meu TCC.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":2047},"LeftTop":{"X":940,"Y":1961},"RightBottom":{"X":1679,"Y":2047},"RightTop":{"X":1679,"Y":1961}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"figure","Text":"","Level":0,"Po