"Y":1640},"RightTop":{"X":833,"Y":1602}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"Durante o desenvolvimento embrionário humano ocorre uma comunicação entre os átrios direito e esquerdo através do forame oval (ou forame de Botal). Essa comunicação não causa prejuízos à circulação do bebê em formação, exceto se ela perdurar após o nascimento.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1832},"LeftTop":{"X":99,"Y":1678},"RightBottom":{"X":1683,"Y":1832},"RightTop":{"X":1683,"Y":1678}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"Os prejuízos no período embrionário são evitados porque a circulação fetal se assemelha à dos(as)","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1908},"LeftTop":{"X":104,"Y":1867},"RightBottom":{"X":1506,"Y":1908},"RightTop":{"X":1506,"Y":1867}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"A aves, porque a pequena circulação e a grande circulação estão presentes.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1988},"LeftTop":{"X":104,"Y":1951},"RightBottom":{"X":1211,"Y":1988},"RightTop":{"X":1211,"Y":1951}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"B répteis, porque a mistura de sangue é minimizada por um metabolismo lento.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":2067},"LeftTop":{"X":108,"Y":2029},"RightBottom":{"X":1247,"Y":2067},"RightTop":{"X":1247,"Y":2029}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"crocodilianos, porque a separação dos ventrículos impede a mistura sanguínea.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":2148},"LeftTop":{"X":108,"Y":2112},"RightBottom":{"X":1286,"Y":2148},"RightTop":{"X":1286,"Y":2112}},"InsetImageName":"","E