{"PageNumber":76,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Fredão","Level":0,"Polygon":{"LeftBottom":{"X":740,"Y":205},"LeftTop":{"X":740,"Y":16},"RightBottom":{"X":1047,"Y":205},"RightTop":{"X":1047,"Y":16}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Questão 146 (H14 | Enem 2022) Dificuldade 750,1","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":273},"LeftTop":{"X":104,"Y":235},"RightBottom":{"X":833,"Y":273},"RightTop":{"X":833,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Antimicrobianos são substâncias naturais ou sintéticas que têm capacidade de matar ou inibir o crescimento de microrganismos. A tabela apresenta uma lista de antimicrobianos hipotéticos, bem como suas ações e efeitos sobre o metabolismo microbiano.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":455},"LeftTop":{"X":99,"Y":311},"RightBottom":{"X":1683,"Y":455},"RightTop":{"X":1683,"Y":311}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"table","Text":"<table><tr><td>Antimicrobiano</td><td>Ação</td><td>Efeito</td></tr><tr><td>1</td><td>Une-se aos ribossomos</td><td>Impede a síntese proteica</td></tr><tr><td>2</td><td>Une-se aos microtúbulos</td><td>Impede a segregação das cromátides</td></tr><tr><td>3</td><td>Une-se aos fosfolipídeos da membrana plasmática</td><td>Reduz a permeabilidade da membrana plasmática</td></tr><tr><td>4</td><td>Interfere na síntese de timina</td><td>Inibe a síntese de DNA</td></tr><tr><td>5</td><td>Interfere na síntese de uracila</td><td>Impede a síntese de RNA</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":955},"LeftTop":{"X":104,"Y":491},"RightBottom":{"X":1674,"Y":955},"RightTop":{"X":1674,"Y":491}},"InsetImageName":"","Elements":null,"ImagePa