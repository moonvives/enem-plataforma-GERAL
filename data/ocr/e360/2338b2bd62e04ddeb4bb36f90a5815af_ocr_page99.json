se no organismo. O teste é simples e consiste em duas reações sequenciais na superfície do biochip, entre a amostra de soro sanguíneo do paciente, enzimas específicas e reagente (iodeto de potássio, KI), conforme mostrado na imagem.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":619},"LeftTop":{"X":940,"Y":299},"RightBottom":{"X":1683,"Y":619},"RightTop":{"X":1683,"Y":299}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":999,"Y":1150},"LeftTop":{"X":999,"Y":650},"RightBottom":{"X":1619,"Y":1150},"RightTop":{"X":1619,"Y":650}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"(i) Biochip antes da adição de soro","Level":0,"Polygon":{"LeftBottom":{"X":999,"Y":1150},"LeftTop":{"X":999,"Y":650},"RightBottom":{"X":1619,"Y":1150},"RightTop":{"X":1619,"Y":650}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/f4965998f14a8bd8ab194b60be50461d-image.png","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"Após a adição de soro sanguíneo, o fluxo desloca-se espontaneamente da esquerda para a direita (ii) promovendo reações sequenciais, conforme as equações 1 e 2. Na primeira, há conversão de glicose do sangue em ácido glucônico, gerando peróxido de hidrogênio:","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":1415},"LeftTop":{"X":940,"Y":1180},"RightBottom":{"X":1683,"Y":1415},"RightTop":{"X":1683,"Y":1180}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"title","Text":"###  Equação 1","Level":0,"Polygon":{"LeftBottom":{"X":1235,"Y":1481},"LeftTop":{"X":1235,"Y":1443},"RightBottom":{"X":1392,"Y":1481},"RightTop":{"X":1392,"Y":1443}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"paragraph","Text":"$$C_6H_{12}O_6(aq) + O_2(g) + H_2O(l) \\xrightarrow{enzimas} C_6H_{12}O_7