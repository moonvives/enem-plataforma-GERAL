Name":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"No ciclo celular atuam moléculas reguladoras. Dentre elas, a proteína p53 é ativada em resposta a mutações no DNA, evitando a progressão do ciclo até que os danos sejam reparados, ou induzindo a célula à autodestruição.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2329},"LeftTop":{"X":104,"Y":2165},"RightBottom":{"X":843,"Y":2329},"RightTop":{"X":843,"Y":2165}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"ALBERTS, B. et al. Fundamentos da biologia celular. Porto Alegre: Artmed, 2011 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":109,"Y":2400},"LeftTop":{"X":109,"Y":2350},"RightBottom":{"X":842,"Y":2400},"RightTop":{"X":842,"Y":2350}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"A ausência dessa proteína poderá favorecer a","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":268},"LeftTop":{"X":945,"Y":235},"RightBottom":{"X":1601,"Y":268},"RightTop":{"X":1601,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"A redução da síntese de DNA, acelerando o ciclo celular.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":357},"LeftTop":{"X":945,"Y":288},"RightBottom":{"X":1692,"Y":357},"RightTop":{"X":1692,"Y":288}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"B saída imediata do ciclo celular, antecipando a proteção do DNA.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":450},"LeftTop":{"X":945,"Y":379},"RightBottom":{"X":1692,"Y":450},"RightTop":{"X":1692,"Y":379}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"© ativação de outras proteínas reguladoras, induzindo a apoptose.","Level":0,