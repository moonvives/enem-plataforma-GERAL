6,"Y":857}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Os búfalos são animais considerados rústicos pelos criadores e, por isso, são deixados no campo sem controle reprodutivo. Por causa desse tipo de criação, a consanguinidade é favorecida, proporcionando o aparecimento de enfermidades, como o albinismo, defeitos cardíacos, entre outros. Separar os animais de forma adequada minimizaria a ocorrência desses problemas.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1253},"LeftTop":{"X":102,"Y":925},"RightBottom":{"X":840,"Y":1253},"RightTop":{"X":840,"Y":925}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"DAMÉ, M. C. F.; RIET-CORREA, F.; SCHILD, A. L. Pesq. Vet. Bras., n. 7, 2013 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":167,"Y":1342},"LeftTop":{"X":167,"Y":1279},"RightBottom":{"X":840,"Y":1342},"RightTop":{"X":840,"Y":1279}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Qual procedimento biotecnológico prévio é recomendado nessa situação?","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1445},"LeftTop":{"X":102,"Y":1370},"RightBottom":{"X":840,"Y":1445},"RightTop":{"X":840,"Y":1370}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"A Transgenia.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1519},"LeftTop":{"X":104,"Y":1478},"RightBottom":{"X":334,"Y":1519},"RightTop":{"X":334,"Y":1478}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"B Terapia gênica.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1587},"LeftTop":{"X":104,"Y":1549},"RightBottom":{"X":386,"Y":1587},"RightTop":{"X":386,"Y":1549}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Typ