_type":""},{"Index":11,"Type":"paragraph","Text":"D termotropismo negativo.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1708},"LeftTop":{"X":108,"Y":1668},"RightBottom":{"X":506,"Y":1708},"RightTop":{"X":506,"Y":1668}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"E quimiotropismo negativo.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1781},"LeftTop":{"X":108,"Y":1738},"RightBottom":{"X":518,"Y":1781},"RightTop":{"X":518,"Y":1738}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"title","Text":"##  Questão 137 (H14 | Enem 2016) Dificuldade 556,1","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1910},"LeftTop":{"X":104,"Y":1872},"RightBottom":{"X":835,"Y":1910},"RightTop":{"X":835,"Y":1872}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"Portadores de diabetes insipidus reclamam da confusão feita pelos profissionais da saúde quanto aos dois tipos de diabetes: mellitus e insipidus. Enquanto o primeiro tipo está associado aos níveis ou à ação da insulina, o segundo não está ligado à deficiência desse hormônio. O diabetes insipidus é caracterizado por um distúrbio na produção ou no funcionamento do hormônio antidiurético (na sigla em inglês, ADH), secretado pela neuro-hipófise para controlar a reabsorção de água pelos túbulos renais.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2370},"LeftTop":{"X":102,"Y":1938},"RightBottom":{"X":840,"Y":2370},"RightTop":{"X":840,"Y":1938}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"Tendo em vista o papel funcional do ADH, qual é um sintoma clássico de um paciente acometido por diabetes insipidus?","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":342},"LeftTop":{"X":944,"Y":235},"RightBottom":{"X":1679,"Y":342},"RightTop":{"X":1679,"Y":235}},"InsetImageN