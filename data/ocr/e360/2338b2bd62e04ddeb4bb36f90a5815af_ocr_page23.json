{"PageNumber":23,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Fredaw","Level":0,"Polygon":{"LeftBottom":{"X":736,"Y":195},"LeftTop":{"X":736,"Y":16},"RightBottom":{"X":1040,"Y":195},"RightTop":{"X":1040,"Y":16}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Questão 025 (H2 | Enem 2018) Dificuldade 676,5","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":268},"LeftTop":{"X":101,"Y":230},"RightBottom":{"X":815,"Y":268},"RightTop":{"X":815,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Pesquisas demonstram que nanodispositivos baseados em movimentos de dimensões atômicas, induzidos por luz, poderão ter aplicações em tecnologias futuras, substituindo micromotores, sem a necessidade de componentes mecânicos. Exemplo de movimento molecular induzido pela luz pode ser observado pela flexão de uma lâmina delgada de silício, ligado a um polímero de azobenzeno e a um material suporte, em dois comprimentos de onda, conforme ilustrado na figura. Com a aplicação de luz ocorrem reações reversíveis da cadeia do polímero, que promovem o movimento observado.","Level":0,"Polygon":{"LeftBottom":{"X":95,"Y":622},"LeftTop":{"X":95,"Y":306},"RightBottom":{"X":1681,"Y":622},"RightTop":{"X":1681,"Y":306}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":156,"Y":1339},"LeftTop":{"X":156,"Y":667},"RightBottom":{"X":1367,"Y":1339},"RightTop":{"X":1367,"Y":667}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"graph TD     A[365 nm] --> B[420 nm]","Level":0,"Polygon":{"LeftBottom":{"X":156,"Y":1339},"LeftTop":{"X":156,"Y":667},"RightBottom":{"X":1367,"Y":1339},"RightTop":{"X":1367,"Y":667}},"InsetImageName":"","Elemen