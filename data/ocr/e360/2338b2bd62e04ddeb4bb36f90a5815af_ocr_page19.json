{"PageNumber":19,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Redaw","Level":0,"Polygon":{"LeftBottom":{"X":735,"Y":192},"LeftTop":{"X":735,"Y":16},"RightBottom":{"X":1045,"Y":192},"RightTop":{"X":1045,"Y":16}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Competência 1","Level":0,"Polygon":{"LeftBottom":{"X":760,"Y":271},"LeftTop":{"X":760,"Y":230},"RightBottom":{"X":1020,"Y":271},"RightTop":{"X":1020,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Compreender as ciências naturais e as tecnologias a elas associadas como construções humanas, percebendo seus papéis nos processos de produção e no desenvolvimento econômico e social da humanidade.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":362},"LeftTop":{"X":101,"Y":291},"RightBottom":{"X":1676,"Y":362},"RightTop":{"X":1676,"Y":291}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"title","Text":"#  Habilidade 2","Level":0,"Polygon":{"LeftBottom":{"X":783,"Y":422},"LeftTop":{"X":783,"Y":382},"RightBottom":{"X":1002,"Y":422},"RightTop":{"X":1002,"Y":382}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"Associar a solução de problemas de comunicação, transporte, saúde ou outro, com o correspondente desenvolvimento científico e tecnológico.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":511},"LeftTop":{"X":101,"Y":440},"RightBottom":{"X":1679,"Y":511},"RightTop":{"X":1679,"Y":440}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"title","Text":"##  Questão 015 (H2 | Enem 2018) Dificuldade 537,9","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":635},"LeftTop":{"X":104,"Y":599},"RightBottom":{"X":818,"Y":635},"RightTop":{"X":818,"Y":599}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Companhias que fabricam jeans usam cloro para o clareamento, seguido de lavagem. Algumas estão substituindo o cloro por substâncias ambientalmente mais seguras como peróxidos, que podem ser degradados por enzimas chamadas peroxidases. Pensando nisso, pesquisadores inseriram genes codificadores de peroxidases em leveduras cultivadas nas condições de clareamento e lavagem dos jeans e selecionaram as sobreviventes para produção dessas enzimas.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":821},"LeftTop":{"X":101,"Y":655},"RightBottom":{"X":1679,"Y":821},"RightTop":{"X":1679,"Y":655}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"TORTORA, G. J.; FUNKE, B. R.; CASE, C. L. Microbiologia. Rio de Janeiro: Artmed, 2016 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":572,"Y":869},"LeftTop":{"X":572,"Y":837},"RightBottom":{"X":1679,"Y":869},"RightTop":{"X":1679,"Y":837}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Nesse caso, o uso dessas leveduras modificadas objetiva","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":925},"LeftTop":{"X":104,"Y":887},"RightBottom":{"X":915,"Y":925},"RightTop":{"X":915,"Y":887}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"A reduzir a quantidade de resíduos tóxicos nos efluentes da lavagem.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":986},"LeftTop":{"X":108,"Y":948},"RightBottom":{"X":1110,"Y":986},"RightTop":{"X":1110,"Y":948}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"B eliminar a necessidade de tratamento da água consumida.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1046},"LeftTop":{"X":108,"Y":1006},"RightBottom":{"X":985,"Y":1046},"RightTop":{"X":985,"Y":1006}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"elevar a capacidade de clareamento dos jeans.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1107},"LeftTop":{"X":108,"Y":1066},"RightBottom":{"X":827,"Y":1107},"RightTop":{"X":827,"Y":1066}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"D aumentar a resistência do jeans a peróxidos.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1165},"LeftTop":{"X":108,"Y":1125},"RightBottom":{"X":799,"Y":1165},"RightTop":{"X":799,"Y":1125}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"E associar ação bactericida ao clareamento.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1223},"LeftTop":{"X":108,"Y":1185},"RightBottom":{"X":758,"Y":1223},"RightTop":{"X":758,"Y":1185}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"title","Text":"##  Questão 016 (H2 | Enem 2021) Dificuldade 559,1","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1337},"LeftTop":{"X":101,"Y":1299},"RightBottom":{"X":815,"Y":1337},"RightTop":{"X":815,"Y":1299}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"O emprego de células de combustível a hidrogênio pode ser uma tecnologia adequada ao transporte automotivo. O quadro apresenta características de cinco tecnologias mais proeminentes de células de combustível.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1425},"LeftTop":{"X":101,"Y":1357},"RightBottom":{"X":1679,"Y":1425},"RightTop":{"X":1679,"Y":1357}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"table","Text":"<table><tr><td>Tipo de célula de combustível</td><td>Temperatura operacional (°C)</td><td>Eletrólito</td><td>Semirreações nos eletrodos</td></tr><tr><td>AFC</td><td>90 - 100</td><td>Hidróxido de potássio aquoso</td><td>$H_{2}$ + 2 $OH^{-}$ → 2 $H_{2}O$ + 2 $e^{-}$1/2 $O_{2}$ + $H_{2}O$ + 2 $e^{-}$ → 2 $OH^{-}$</td></tr><tr><td>MSFC</td><td>600 - 1 000</td><td>Carbonatos de lítio, sódio e/ou potássio fundidos</td><td>$H_{2}$ + $CO_{3}^{2-}$ → $H_{2}O$ + $CO_{2}$ + 2 $e^{-}$1/2 $O_{2}$ + $CO_{2}$ + 2 $e^{-}$ → $CO_{3}^{2-}$</td></tr><tr><td>PEM</td><td>60 - 100</td><td>Ácido poliperfluorossulfônico sólido</td><td rowspan=\"3\">$H_{2}$ → 2 $H^{+}$ + 2 $e^{-}$1/2 $O_{2}$ + 2 $H^{+}$ + 2 $e^{-}$ → $H_{2}O$</td></tr><tr><td>PAFC</td><td>175 - 200</td><td>Ácido fosfórico líquido</td></tr><tr><td>SOFC</td><td>600 - 1 000</td><td>Óxido de zircônio(IV) sólido</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":242,"Y":2052},"LeftTop":{"X":242,"Y":1448},"RightBottom":{"X":1549,"Y":2052},"RightTop":{"X":1549,"Y":1448}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"Testes operacionais com esses tipos de células têm indicado que as melhores alternativas para veículos são as que operam em baixos níveis de energia térmica, são formadas por membranas de eletrólitos poliméricos e ocorrem em meio ácido.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":2168},"LeftTop":{"X":101,"Y":2072},"RightBottom":{"X":1679,"Y":2168},"RightTop":{"X":1679,"Y":2072}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"THOMAS, S; ZALBOWITZ, M. Full cells: green power. Los Alamos National Laboratory. Los Alamos, NM, 1999 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":356,"Y":2221},"LeftTop":{"X":356,"Y":2191},"RightBottom":{"X":1679,"Y":2221},"RightTop":{"X":1679,"Y":2191}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"A tecnología testada mais adequada para o emprego em veículos automotivos é a célula de combustível","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":2276},"LeftTop":{"X":101,"Y":2241},"RightBottom":{"X":1570,"Y":2276},"RightTop":{"X":1570,"Y":2241}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"A AFC.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2335},"LeftTop":{"X":104,"Y":2294},"RightBottom":{"X":238,"Y":2335},"RightTop":{"X":238,"Y":2294}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"B MSFC.","Level":0,"Polygon":{"LeftBottom":{"X":318,"Y":2335},"LeftTop":{"X":318,"Y":2294},"RightBottom":{"X":483,"Y":2335},"RightTop":{"X":483,"Y":2294}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"![](536,2296,571,2331) PEM.","Level":0,"Polygon":{"LeftBottom":{"X":536,"Y":2335},"LeftTop":{"X":536,"Y":2294},"RightBottom":{"X":676,"Y":2335},"RightTop":{"X":676,"Y":2294}},"InsetImageName":"","Elements":null,"ImagePath":"images/8e002316d001625238d08b60062c09f2-image.png","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"![](751,2296,785,2331)  PAFC.","Level":0,"Polygon":{"LeftBottom":{"X":752,"Y":2335},"LeftTop":{"X":752,"Y":2294},"RightBottom":{"X":908,"Y":2335},"RightTop":{"X":908,"Y":2294}},"InsetImageName":"","Elements":null,"ImagePath":"images/9b1843fb312771cf5e02d22f86717d1b-image.png","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"![](965,2296,1000,2331)  SOFC.","Level":0,"Polygon":{"LeftBottom":{"X":965,"Y":2335},"LeftTop":{"X":965,"Y":2294},"RightBottom":{"X":1127,"Y":2335},"RightTop":{"X":1127,"Y":2294}},"InsetImageName":"","Elements":null,"ImagePath":"images/453d601dde75d29ab7a1054cf05b867f-image.png","group_id":-1,"group_type":""},{"Index":25,"Type":"footer","Text":"Competência 1 | Enem 360 – Versão Ciências da Nature