{"PageNumber":31,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"Professor Fredaw","Level":0,"Polygon":{"LeftBottom":{"X":740,"Y":195},"LeftTop":{"X":740,"Y":16},"RightBottom":{"X":1042,"Y":195},"RightTop":{"X":1042,"Y":16}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"title","Text":"#  Competência 1","Level":0,"Polygon":{"LeftBottom":{"X":760,"Y":276},"LeftTop":{"X":760,"Y":235},"RightBottom":{"X":1024,"Y":276},"RightTop":{"X":1024,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Compreender as ciências naturais e as tecnologias a elas associadas como construções humanas, percebendo seus papéis nos processos de produção e no desenvolvimento econômico e social da humanidade.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":415},"LeftTop":{"X":102,"Y":319},"RightBottom":{"X":1683,"Y":415},"RightTop":{"X":1683,"Y":319}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"title","Text":"#  Habilidade 4","Level":0,"Polygon":{"LeftBottom":{"X":786,"Y":496},"LeftTop":{"X":786,"Y":453},"RightBottom":{"X":1002,"Y":496},"RightTop":{"X":1002,"Y":453}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"Avaliar propostas de intervenção no ambiente, considerando a qualidade da vida humana ou medidas de conservação, recuperação ou utilização sustentável da biodiversidade.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":635},"LeftTop":{"X":104,"Y":536},"RightBottom":{"X":1683,"Y":635},"RightTop":{"X":1683,"Y":536}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"title","Text":"##  Questão 041 (H4 | Enem 2019) Dificuldade 525,5","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":779},"LeftTop":{"X":104,"Y":741},"RightBottom":{"X":822,"Y":779},"RightTop":{"X":822,"Y":741}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"No quadro estão apresentadas informações sobre duas estratégias de sobrevivência que podem ser adotadas por algumas espécies de seres vivos.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":887},"LeftTop":{"X":104,"Y":806},"RightBottom":{"X":1683,"Y":887},"RightTop":{"X":1683,"Y":806}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"table","Text":"<table><tr><td></td><td>Estratégia 1</td><td>Estratégia 2</td></tr><tr><td>Hábitat</td><td>Mais instável e imprevisível</td><td>Mais estável e previsível</td></tr><tr><td>Potencial biótico</td><td>Muito elevado</td><td>Baixo</td></tr><tr><td>Duração da vida</td><td>Curta e com reprodução precoce</td><td>Longa e com reprodução tardia</td></tr><tr><td>Descendentes</td><td>Muitos e com tamanho corporal pequeno</td><td>Poucos e com tamanho corporal maior</td></tr><tr><td>Tamanho populacional</td><td>Variável</td><td>Constante</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":129,"Y":1208},"LeftTop":{"X":129,"Y":905},"RightBottom":{"X":1656,"Y":1208},"RightTop":{"X":1656,"Y":905}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Na recuperação de uma área desmatada deveriam ser reintroduzidas primeiramente as espécies que adotam qual estratégia?","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1309},"LeftTop":{"X":102,"Y":1231},"RightBottom":{"X":1683,"Y":1309},"RightTop":{"X":1683,"Y":1231}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"A Estratégia 1, pois essas espécies produzem descendentes pequenos, o que diminui a competição com outras espécies.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1413},"LeftTop":{"X":104,"Y":1334},"RightBottom":{"X":1670,"Y":1413},"RightTop":{"X":1670,"Y":1334}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"B Estratégia 2, pois essas espécies têm uma longa duração da vida, o que favorece a produção de muitos descendentes.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1516},"LeftTop":{"X":108,"Y":1438},"RightBottom":{"X":1674,"Y":1516},"RightTop":{"X":1674,"Y":1438}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"Estratégia 1, pois essas espécies apresentam um elevado potencial biótico, o que facilita a rápida recolonização da área desmatada.","Level":0,"Polygon":{"LeftBottom":{"X":108,"Y":1627},"LeftTop":{"X":108,"Y":1544},"RightBottom":{"X":1669,"Y":1627},"RightTop":{"X":1669,"Y":1544}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"Estratégia 2, pois essas espécies estão adaptadas a hábitats mais estáveis, o que corresponde ao ambiente de uma área desmatada.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1723},"LeftTop":{"X":104,"Y":1647},"RightBottom":{"X":1674,"Y":1723},"RightTop":{"X":1674,"Y":1647}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Estratégia 2, pois essas espécies apresentam um tamanho populacional constante, o que propicia uma recolonização mais estável da área desmatada.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1827},"LeftTop":{"X":104,"Y":1751},"RightBottom":{"X":1674,"Y":1827},"RightTop":{"X":1674,"Y":1751}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"footer","Text":"Página40","Level":0,"Polygon":{"LeftBottom":{"X":1713,"Y":2393},"LeftTop":{"X":1713,"Y":2228},"RightBottom":{"X":1761,"Y":2393},"RightTop":{"X":1761,"Y":2228}},"InsetImageName":"","Elements":null,"ImagePath":"","group