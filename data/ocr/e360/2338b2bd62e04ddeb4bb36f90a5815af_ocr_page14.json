o da passagem de um veículo sobre ele, alertando para uma situação atípica à frente, como obras, pedágios ou travessia de pedestres. Ao passar sobre os sonorizadores, a suspensão do veículo sofre, vibrações que produzem ondas sonoras, resultando em um barulho peculiar. Considere um veículo que passe com velocidade constante igual a 108 km/h sobre um sonorizador cujas faixas são separadas por uma distância de 8 cm.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2054},"LeftTop":{"X":102,"Y":1471},"RightBottom":{"X":840,"Y":2054},"RightTop":{"X":840,"Y":1471}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"Disponível em: www.denatran.gov.br. Acesso em: 2 set. 2015\n(adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":179,"Y":2153},"LeftTop":{"X":179,"Y":2087},"RightBottom":{"X":840,"Y":2153},"RightTop":{"X":840,"Y":2087}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"A frequência da vibração do automóvel percebida pelo condutor durante a passagem nesse sonorizador é mais próxima de","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2309},"LeftTop":{"X":102,"Y":2185},"RightBottom":{"X":840,"Y":2309},"RightTop":{"X":840,"Y":2185}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"A 8.6 hertz.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":268},"LeftTop":{"X":945,"Y":235},"RightBottom":{"X":1140,"Y":268},"RightTop":{"X":1140,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"B 13,5 hertz.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":344},"LeftTop":{"X":945,"Y":309},"RightBottom":{"X":1154,"Y":344},"RightTop":{"X":1154,"Y":309}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"© 375 hertz.","Level":0,"Polyg