.png","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Os gráficos indicam, em tempo real, o sinal sonoro detectado pelos dois dispositivos, os quais foram ligados simultaneamente em um instante anterior à queda do bloco de gelo. Ao comparar pontos correspondentes desse sinal em cada dispositivo, é possível obter informações sobre a onda sonora.","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1865},"LeftTop":{"X":938,"Y":1640},"RightBottom":{"X":1686,"Y":1865},"RightTop":{"X":1686,"Y":1640}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":999,"Y":2145},"LeftTop":{"X":999,"Y":1890},"RightBottom":{"X":1720,"Y":2145},"RightTop":{"X":1720,"Y":1890}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"23 222 232 244 Tempo (s)","Level":0,"Polygon":{"LeftBottom":{"X":999,"Y":2145},"LeftTop":{"X":999,"Y":1890},"RightBottom":{"X":1720,"Y":2145},"RightTop":{"X":1720,"Y":1890}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/bda927e60f07419e7f27d3448a5b3ed6-image.png","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"A distância L, em metro, entre o barco e a geleira é mais próxima de","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":2241},"LeftTop":{"X":938,"Y":2168},"RightBottom":{"X":1681,"Y":2241},"RightTop":{"X":1681,"Y":2168}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"A 339 000. B 78 900. ![](1442,2271,1476,2309)  14 400.\n5 240 E 100","Level":0,"Polygon":{"LeftBottom":{"X":956,"Y":2345},"LeftTop":{"X":956,"Y":2274},"RightBottom":{"X":1604,"Y":2345},"RightTop":{"X":1604,"Y":2274}},"InsetImageName":"","Elements":null,"ImagePath":"images/35b391ea016adedcb44372b137e4e96d-image.png","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"D 5240. E 100.","Level":0,