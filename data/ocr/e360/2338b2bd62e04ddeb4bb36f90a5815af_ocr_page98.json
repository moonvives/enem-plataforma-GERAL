Index":11,"Type":"paragraph","Text":"As pessoas que utilizam objetos cujo princípio de funcionamento é o mesmo do das alavancas aplicam uma força, chamada de força potente, em um dado ponto da barra, para superar ou equilibrar uma segunda força, chamada de resistente, em outro ponto da barra. Por causa das diferentes distâncias entre os pontos de aplicação das forças, potente e resistente, os seus efeitos também são diferentes. A figura mostra alguns exemplos desses objetos.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1700},"LeftTop":{"X":99,"Y":1367},"RightBottom":{"X":843,"Y":1700},"RightTop":{"X":843,"Y":1367}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":118,"Y":2077},"LeftTop":{"X":118,"Y":1711},"RightBottom":{"X":827,"Y":2077},"RightTop":{"X":827,"Y":1711}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"Abridor de garrafa","Level":0,"Polygon":{"LeftBottom":{"X":118,"Y":2077},"LeftTop":{"X":118,"Y":1711},"RightBottom":{"X":827,"Y":2077},"RightTop":{"X":827,"Y":1711}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/f48602e1b14fd60fba911e3c66519964-image.png","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Em qual dos objetos a força potente é maior que a força resistente?","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":2170},"LeftTop":{"X":99,"Y":2097},"RightBottom":{"X":843,"Y":2170},"RightTop":{"X":843,"Y":2097}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"A Pinça.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2239},"LeftTop":{"X":102,"Y":2193},"RightBottom":{"X":258,"Y":2239},"RightTop":{"X":258,"Y":2193}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"D Carrinho de mão.","Level":0,"Polygon":{"Le