40,"Y":1274}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"As proteínas de uma célula eucariótica possuem peptídeos sinais, que são sequências de aminoácidos responsáveis pelo seu endereçamento para as diferentes organelas, de acordo com suas funções. Um pesquisador desenvolveu uma nanopartícula capaz de carregar proteínas para dentro de tipos celulares específicos. Agora ele quer saber se uma nanopartícula carregada com uma proteína bloqueadora do ciclo de Krebs in vitro é capaz de exercer sua atividade em uma célula cancerosa, podendo cortar o aporte energético e destruir essas células.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1837},"LeftTop":{"X":99,"Y":1342},"RightBottom":{"X":843,"Y":1837},"RightTop":{"X":843,"Y":1342}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Ao escolher essa proteína bloqueadora para carregar as nanopartículas, o pesquisador deve levar em conta um peptídeo sinal de endereçamento para qual organela?","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":2026},"LeftTop":{"X":99,"Y":1865},"RightBottom":{"X":840,"Y":2026},"RightTop":{"X":840,"Y":1865}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"A Núcleo.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2097},"LeftTop":{"X":102,"Y":2054},"RightBottom":{"X":277,"Y":2097},"RightTop":{"X":277,"Y":2054}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"B Mitocôndria.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2163},"LeftTop":{"X":102,"Y":2127},"RightBottom":{"X":338,"Y":2163},"RightTop":{"X":338,"Y":2127}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"C Peroxissomo.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2231},"LeftT