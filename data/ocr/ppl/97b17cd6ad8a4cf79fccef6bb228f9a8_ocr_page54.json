e uma população de onças foi isolada em uma mata pequena. Elas se extinguiriam mesmo sem terem sido abatidas. Diversos componentes da ilha de hábitat, como o tamanho, a heterogeneidade, o seu entorno, a sua conectividade e o efeito de borda são determinantes para a persistência ou não das espécies originais.","Level":0,"Polygon":{"LeftBottom":{"X":933,"Y":698},"LeftTop":{"X":933,"Y":294},"RightBottom":{"X":1686,"Y":698},"RightTop":{"X":1686,"Y":294}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"Uma medida que auxilia na conservação da biodiversidade nas ilhas mencionadas no texto compreende a","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":829},"LeftTop":{"X":936,"Y":715},"RightBottom":{"X":1686,"Y":829},"RightTop":{"X":1686,"Y":715}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"A formação de micro-hábitats.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":895},"LeftTop":{"X":942,"Y":852},"RightBottom":{"X":1403,"Y":895},"RightTop":{"X":1403,"Y":852}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"B ampliação do efeito de borda.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":958},"LeftTop":{"X":942,"Y":915},"RightBottom":{"X":1429,"Y":958},"RightTop":{"X":1429,"Y":915}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"paragraph","Text":"C construção de corredores ecológicos.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1018},"LeftTop":{"X":942,"Y":976},"RightBottom":{"X":1536,"Y":1018},"RightTop":{"X":1536,"Y":976}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"paragraph","Text":"D promoção da sucessão ecológica.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1082},"LeftTop":{"X":942,"Y":1039},"RightBottom":{"X":1488,"Y":1082},"Right