{"PageNumber":34,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"H2: Ciência, Tecnologia e Solução de Problemas","Level":0,"Polygon":{"LeftBottom":{"X":458,"Y":152},"LeftTop":{"X":458,"Y":104},"RightBottom":{"X":1333,"Y":152},"RightTop":{"X":1333,"Y":104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"header","Text":"Professor Professor Redão","Level":0,"Polygon":{"LeftBottom":{"X":1449,"Y":220},"LeftTop":{"X":1449,"Y":109},"RightBottom":{"X":1685,"Y":220},"RightTop":{"X":1685,"Y":109}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"title","Text":"#  Competência 1","Level":0,"Polygon":{"LeftBottom":{"X":340,"Y":278},"LeftTop":{"X":340,"Y":235},"RightBottom":{"X":604,"Y":278},"RightTop":{"X":604,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"Compreender as ciências naturais e as tecnologias a elas associadas como construções humanas, percebendo seus papéis nos processos de produção e no desenvolvimento econômico e social da humanidade.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":574},"LeftTop":{"X":99,"Y":319},"RightBottom":{"X":842,"Y":574},"RightTop":{"X":842,"Y":319}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"title","Text":"#  Habilidade 2","Level":0,"Polygon":{"LeftBottom":{"X":361,"Y":660},"LeftTop":{"X":361,"Y":617},"RightBottom":{"X":583,"Y":660},"RightTop":{"X":583,"Y":617}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"Associar a solução de problemas de comunicação, transporte, saúde ou outro, com o correspondente desenvolvimento científico e tecnológico.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":847},"LeftTop":{"X":99,"Y":700},"RightBottom":{"X":840,"Y":847},"RightTop":{"X":840,"Y":700}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"title","Text":"##  Questão 026 (H2 | 2023 | 454,4) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":935},"LeftTop":{"X":101,"Y":892},"RightBottom":{"X":781,"Y":935},"RightTop":{"X":781,"Y":892}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"É comum em viagens de avião sermos solicitados a desligar aparelhos cujo funcionamento envolva a emissão ou a recepção de ondas eletromagnéticas, como celulares. A justificativa dada para esse procedimento é, entre outras coisas, a necessidade de eliminar fontes de sinais eletromagnéticos que possam interferir nas comunicações, via rádio, dos pilotos com a torre de controle.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1294},"LeftTop":{"X":99,"Y":960},"RightBottom":{"X":840,"Y":1294},"RightTop":{"X":840,"Y":960}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Essa interferência poderá ocorrer somente se as ondas emitidas pelo celular e as recebidas pelo rádio do avião","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1438},"LeftTop":{"X":101,"Y":1319},"RightBottom":{"X":840,"Y":1438},"RightTop":{"X":840,"Y":1319}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"A forem ambas audíveis.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1511},"LeftTop":{"X":104,"Y":1471},"RightBottom":{"X":492,"Y":1511},"RightTop":{"X":492,"Y":1471}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"B tiverem a mesma potência.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1579},"LeftTop":{"X":104,"Y":1541},"RightBottom":{"X":549,"Y":1579},"RightTop":{"X":549,"Y":1541}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"tiverem a mesma frequência.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1650},"LeftTop":{"X":104,"Y":1610},"RightBottom":{"X":577,"Y":1650},"RightTop":{"X":577,"Y":1610}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"D tiverem a mesma intensidade.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1718},"LeftTop":{"X":104,"Y":1678},"RightBottom":{"X":592,"Y":1718},"RightTop":{"X":592,"Y":1678}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"E propagarem-se com velocidades diferentes.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1786},"LeftTop":{"X":104,"Y":1748},"RightBottom":{"X":783,"Y":1786},"RightTop":{"X":783,"Y":1748}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"title","Text":"##  Questão 027 (H2 | 2018 | 537,9) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":273},"LeftTop":{"X":942,"Y":230},"RightBottom":{"X":1620,"Y":273},"RightTop":{"X":1620,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"Companhias que fabricam jeans usam cloro para o clareamento, seguido de lavagem. Algumas estão substituindo o cloro por substâncias ambientalmente mais seguras como peróxidos, que podem ser degradados por enzimas chamadas peroxidases. Pensando nisso, pesquisadores inseriram genes codificadores de peroxidases em leveduras cultivadas nas condições de clareamento e lavagem dos jeans e selecionaram as sobreviventes para produção dessas enzimas.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":662},"LeftTop":{"X":942,"Y":296},"RightBottom":{"X":1683,"Y":662},"RightTop":{"X":1683,"Y":296}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"TORTORA, G. J.; FUNKE, B. R.; CASE, C. L. Microbiologia. Rio de Janeiro: Artmed, 2016 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":956,"Y":720},"LeftTop":{"X":956,"Y":670},"RightBottom":{"X":1679,"Y":720},"RightTop":{"X":1679,"Y":670}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"Nesse caso, o uso dessas leveduras modificadas objetiva","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":804},"LeftTop":{"X":942,"Y":731},"RightBottom":{"X":1679,"Y":804},"RightTop":{"X":1679,"Y":731}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"A reduzir a quantidade de resíduos tóxicos nos efluentes da lavagem.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":905},"LeftTop":{"X":944,"Y":829},"RightBottom":{"X":1642,"Y":905},"RightTop":{"X":1642,"Y":829}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"Ⓑ eliminar a necessidade de tratamento da água consumida.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":998},"LeftTop":{"X":944,"Y":928},"RightBottom":{"X":1660,"Y":998},"RightTop":{"X":1660,"Y":928}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"elevar a capacidade de clareamento dos jeans.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1061},"LeftTop":{"X":945,"Y":1021},"RightBottom":{"X":1670,"Y":1061},"RightTop":{"X":1670,"Y":1021}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"D aumentar a resistência do jeans a peróxidos.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1125},"LeftTop":{"X":945,"Y":1084},"RightBottom":{"X":1642,"Y":1125},"RightTop":{"X":1642,"Y":1084}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"E associar ação bactericida ao clareamento.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1190},"LeftTop":{"X":945,"Y":1150},"RightBottom":{"X":1603,"Y":1190},"RightTop":{"X":1603,"Y":1150}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"title","Text":"##  Questão 028 (H2 | 2015 | 555,0) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1301},"LeftTop":{"X":942,"Y":1258},"RightBottom":{"X":1620,"Y":1301},"RightTop":{"X":1620,"Y":1258}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"Tanto a febre amarela quanto a dengue são doenças causadas por vírus do grupo dos arbovírus, pertencentes ao gênero Flavivirus, existindo quatro sorotipos para o vírus causador da dengue. A transmissão de ambas acontece por meio da picada de mosquitos, como o Aedes aegypti. Entretanto, embora compartilhem essas características, hoje somente existe vacina, no Brasil, para a febre amarela e nenhuma vacina efetiva para a dengue.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1658},"LeftTop":{"X":942,"Y":1324},"RightBottom":{"X":1685,"Y":1658},"RightTop":{"X":1685,"Y":1324}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"paragraph","Text":"MINISTÉRIO DA SAÚDE. Fundação Nacional de Saúde. Dengue: Instruções para pessoal de combate ao vetor. Manual de Normas Técnicas. Disponível em: http://portal.saude.gov.br. Acesso em: 7 ago. 2012 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":952,"Y":1738},"LeftTop":{"X":952,"Y":1665},"RightBottom":{"X":1685,"Y":1738},"RightTop":{"X":1685,"Y":1665}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"paragraph","Text":"Esse fato pode ser atribuído à","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1784},"LeftTop":{"X":944,"Y":1748},"RightBottom":{"X":1372,"Y":1784},"RightTop":{"X":1372,"Y":1748}},"InsetImageName":"","Elements":null,"ImagePath":""