{"PageNumber":52,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"H4: Sustentabilidade e Conservação Ambiental","Level":0,"Polygon":{"LeftBottom":{"X":472,"Y":152},"LeftTop":{"X":472,"Y":104},"RightBottom":{"X":1315,"Y":152},"RightTop":{"X":1315,"Y":104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"header","Text":"Professor Professor Predov","Level":0,"Polygon":{"LeftBottom":{"X":1449,"Y":256},"LeftTop":{"X":1449,"Y":104},"RightBottom":{"X":1686,"Y":256},"RightTop":{"X":1686,"Y":104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"title","Text":"#  Competência 1","Level":0,"Polygon":{"LeftBottom":{"X":760,"Y":278},"LeftTop":{"X":760,"Y":235},"RightBottom":{"X":1019,"Y":278},"RightTop":{"X":1019,"Y":235}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"Compreender as ciências naturais e as tecnologias a elas associadas como construções humanas, percebendo seus papéis nos processos de produção e no desenvolvimento econômico e social da humanidade.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":377},"LeftTop":{"X":99,"Y":296},"RightBottom":{"X":1683,"Y":377},"RightTop":{"X":1683,"Y":296}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"title","Text":"#  Habilidade 4","Level":0,"Polygon":{"LeftBottom":{"X":777,"Y":435},"LeftTop":{"X":777,"Y":397},"RightBottom":{"X":1001,"Y":435},"RightTop":{"X":1001,"Y":397}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"Avaliar propostas de intervenção no ambiente, considerando a qualidade da vida humana ou medidas de conservação, recuperação ou utilização sustentável da biodiversidade.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":536},"LeftTop":{"X":99,"Y":458},"RightBottom":{"X":1683,"Y":536},"RightTop":{"X":1683,"Y":458}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Questão 069 (H4 | 2023 | 514,7) 1 ②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":604},"LeftTop":{"X":101,"Y":559},"RightBottom":{"X":777,"Y":604},"RightTop":{"X":777,"Y":559}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"O número de abelhas encontra-se em declínio em várias regiões do mundo, inclusive no Brasil, sendo que vários fatores contribuem para o colapso de suas colmeias. Nos Estados Unidos, bombas de sementes de espécies vegetais nativas têm sido utilizadas para combater o desaparecimento desses insetos. Elas são pequenas bolinhas recheadas com sementes, adubo e argila. Quando são arremessadas e ficam expostas ao sol e à chuva, germinam até mesmo em solo pouco fértil.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":809},"LeftTop":{"X":99,"Y":624},"RightBottom":{"X":1683,"Y":809},"RightTop":{"X":1683,"Y":624}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"DARAYA, V. Disponível em: http://planetasustentavel.abril.com.br. Acesso em: 2 fev. 2015 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":579,"Y":852},"LeftTop":{"X":579,"Y":814},"RightBottom":{"X":1679,"Y":852},"RightTop":{"X":1679,"Y":814}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"Esse método contribui para a preservação das abelhas porque","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":900},"LeftTop":{"X":101,"Y":857},"RightBottom":{"X":986,"Y":900},"RightTop":{"X":986,"Y":857}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"A reduz sua predação.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":960},"LeftTop":{"X":104,"Y":922},"RightBottom":{"X":456,"Y":960},"RightTop":{"X":456,"Y":922}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"B reduz o uso de pesticidas.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1024},"LeftTop":{"X":104,"Y":986},"RightBottom":{"X":533,"Y":1024},"RightTop":{"X":533,"Y":986}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"© reduz a competição por abrigo.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1089},"LeftTop":{"X":104,"Y":1046},"RightBottom":{"X":602,"Y":1089},"RightTop":{"X":602,"Y":1046}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"D aumenta a oferta de alimento.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1152},"LeftTop":{"X":104,"Y":1112},"RightBottom":{"X":588,"Y":1152},"RightTop":{"X":588,"Y":1112}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"E aumenta os locais de reprodução.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1216},"LeftTop":{"X":104,"Y":1175},"RightBottom":{"X":643,"Y":1216},"RightTop":{"X":643,"Y":1175}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"Questão 070 (H4 | 2019 | 525,5) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1339},"LeftTop":{"X":101,"Y":1291},"RightBottom":{"X":777,"Y":1339},"RightTop":{"X":777,"Y":1291}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"No quadro estão apresentadas informações sobre duas estratégias de sobrevivência que podem ser adotadas por algumas espécies de seres vivos.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1433},"LeftTop":{"X":99,"Y":1357},"RightBottom":{"X":1683,"Y":1433},"RightTop":{"X":1683,"Y":1357}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"table","Text":"<table><tr><td></td><td>Estratégia 1</td><td>Estratégia 2</td></tr><tr><td>Hábitat</td><td>Mais instável e imprevisível</td><td>Mais estável e previsível</td></tr><tr><td>Potencial biótico</td><td>Muito elevado</td><td>Baixo</td></tr><tr><td>Duração da vida</td><td>Curta e com reprodução precoce</td><td>Longa e com reprodução tardia</td></tr><tr><td>Descendentes</td><td>Muitos e com tamanho corporal pequeno</td><td>Poucos e com tamanho corporal maior</td></tr><tr><td>Tamanho populacional</td><td>Variável</td><td>Constante</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":127,"Y":1756},"LeftTop":{"X":127,"Y":1453},"RightBottom":{"X":1656,"Y":1756},"RightTop":{"X":1656,"Y":1453}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"Na recuperação de uma área desmatada deveriam ser reintroduzidas primeiramente as espécies que adotam qual estratégia?","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1852},"LeftTop":{"X":99,"Y":1771},"RightBottom":{"X":1683,"Y":1852},"RightTop":{"X":1683,"Y":1771}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"A Estratégia 1, pois essas espécies produzem descendentes pequenos, o que diminui a competição com outras espécies.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1948},"LeftTop":{"X":104,"Y":1872},"RightBottom":{"X":1665,"Y":1948},"RightTop":{"X":1665,"Y":1872}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"Ⓑ Estratégia 2, pois essas espécies têm uma longa duração da vida, o que favorece a produção de muitos descendentes.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2044},"LeftTop":{"X":104,"Y":1968},"RightBottom":{"X":1665,"Y":2044},"RightTop":{"X":1665,"Y":1968}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"Estratégia 1, pois essas espécies apresentam um elevado potencial biótico, o que facilita a rápida recolonização da área desmatada.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2143},"LeftTop":{"X":104,"Y":2067},"RightBottom":{"X":1665,"Y":2143},"RightTop":{"X":1665,"Y":2067}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"Estratégia 2, pois essas espécies estão adaptadas a hábitats mais estáveis, o que corresponde ao ambiente de uma área desmatada.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2236},"LeftTop":{"X":104,"Y":2160},"RightBottom":{"X":1665,"Y":2236},"RightTop":{"X":1665,"Y":2160}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"E Estratégia 2, pois essas espécies apresentam um tamanho populacional constante, o que propicia uma recolonização mais estável da área desmatada.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2337},"LeftTop":{"X":104,"Y":2256},"RightBottom":{"X":1665,"Y":2337},"RightTop":{"X":1665,"Y":2256}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"footer","Text":"Página 58","Level":0,"Polygon":{"LeftBottom":{"X":1708,"Y":2390},"LeftTop":{"X":1708,"Y":2226},"RightBottom":{"X":1763,"Y":2390},"RightTop":{"X":1763,"Y":2226}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"footer","Text":"Competência 1 | Natureza por Habilidades e Dificuldades dos Itens","Level":0,"Polygon":{"LeftBottom":{"X":486,"Y":2479},"LeftTop":{"X":486,"Y":2441},"RightBottom":{"X":1317,"Y":2479},"RightTop":{"X":1317,"Y":2441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}