{"PageNumber":86,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"H8: Etapas de Processos Biológicos, Químicos ou Físicos","Level":0,"Polygon":{"LeftBottom":{"X":370,"Y":152},"LeftTop":{"X":370,"Y":107},"RightBottom":{"X":1408,"Y":152},"RightTop":{"X":1408,"Y":107}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"header","Text":"Professor Professor Redão","Level":0,"Polygon":{"LeftBottom":{"X":1453,"Y":220},"LeftTop":{"X":1453,"Y":114},"RightBottom":{"X":1685,"Y":220},"RightTop":{"X":1685,"Y":114}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"title","Text":"#  Questão 137 (H8 | 2019 | 586,8) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":273},"LeftTop":{"X":102,"Y":230},"RightBottom":{"X":779,"Y":273},"RightTop":{"X":779,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"Na família Retroviridae encontram-se diversos vírus que infectam aves e mamíferos, sendo caracterizada pela produção de DNA a partir de uma molécula de RNA. Alguns retrovírus infectam exclusivamente humanos, não necessitando de outros hospedeiros, reservatórios ou vetores biológicos. As infecções ocasionadas por esses vírus vêm causando mortes e grandes prejuízos ao desenvolvimento social e econômico. Nesse contexto, pesquisadores têm produzido medicamentos que contribuem para o tratamento dessas doenças.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":736},"LeftTop":{"X":102,"Y":301},"RightBottom":{"X":842,"Y":736},"RightTop":{"X":842,"Y":301}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"Que avanços tecnológicos têm contribuído para o tratamento dessas infecções virais?","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":839},"LeftTop":{"X":102,"Y":763},"RightBottom":{"X":842,"Y":839},"RightTop":{"X":842,"Y":763}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"A Melhoria dos métodos de controle dos vetores desses vírus.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":943},"LeftTop":{"X":104,"Y":867},"RightBottom":{"X":854,"Y":943},"RightTop":{"X":854,"Y":867}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"B Fabricação de soros mutagênicos para combate desses vírus.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1044},"LeftTop":{"X":104,"Y":970},"RightBottom":{"X":854,"Y":1044},"RightTop":{"X":854,"Y":970}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"© Investimento da indústria em equipamentos de proteção individual.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1152},"LeftTop":{"X":104,"Y":1074},"RightBottom":{"X":854,"Y":1152},"RightTop":{"X":854,"Y":1074}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"D Produção de vacinas que evitam a infecção das células hospedeiras.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1253},"LeftTop":{"X":104,"Y":1178},"RightBottom":{"X":854,"Y":1253},"RightTop":{"X":854,"Y":1178}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"E Desenvolvimento de antirretrovirais que dificultam a reprodução desses vírus.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1359},"LeftTop":{"X":104,"Y":1281},"RightBottom":{"X":854,"Y":1359},"RightTop":{"X":854,"Y":1281}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"title","Text":"#  Questão 138 (H8 | 2023 | 601,2) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1488},"LeftTop":{"X":102,"Y":1445},"RightBottom":{"X":779,"Y":1488},"RightTop":{"X":779,"Y":1445}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"Barbatimão é o nome popular de uma árvore cuja casca é utilizada para fins medicinais. Essa casca é constituída principalmente de dois tecidos vegetais: periderme e floema. A extração da casca tem levado à morte muitos indivíduos dessa espécie, quando o corte retira um anel completo ao longo da circunferência do tronco. Aqueles que têm parte da casca retirada sem completar essa circunferência podem sobreviver.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1872},"LeftTop":{"X":102,"Y":1519},"RightBottom":{"X":842,"Y":1872},"RightTop":{"X":842,"Y":1519}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"A morte desses indivíduos, decorrente da retirada do anel completo da casca, é provocada pela interrupção da","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2016},"LeftTop":{"X":102,"Y":1900},"RightBottom":{"X":842,"Y":2016},"RightTop":{"X":842,"Y":1900}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"A fotossíntese.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2082},"LeftTop":{"X":104,"Y":2047},"RightBottom":{"X":347,"Y":2082},"RightTop":{"X":347,"Y":2047}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"B transpiração.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2153},"LeftTop":{"X":104,"Y":2115},"RightBottom":{"X":351,"Y":2153},"RightTop":{"X":351,"Y":2115}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"troca de gases.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2216},"LeftTop":{"X":104,"Y":2183},"RightBottom":{"X":386,"Y":2216},"RightTop":{"X":386,"Y":2183}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"D formação de brotos.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2284},"LeftTop":{"X":104,"Y":2246},"RightBottom":{"X":451,"Y":2284},"RightTop":{"X":451,"Y":2246}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"E nutrição das raízes.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2352},"LeftTop":{"X":104,"Y":2314},"RightBottom":{"X":447,"Y":2352},"RightTop":{"X":447,"Y":2314}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"title","Text":"##  Questão 139 (H8 | 2012 | 602,8) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":273},"LeftTop":{"X":944,"Y":230},"RightBottom":{"X":1620,"Y":273},"RightTop":{"X":1620,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"O boato de que os lacres das latas de alumínio teriam um alto valor comercial levou muitas pessoas a juntarem esse material na expectativa de ganhar dinheiro com sua venda. As empresas fabricantes de alumínio esclarecem que isso não passa de uma “lenda urbana”, pois ao retirar o anel da lata, dificulta-se a reciclagem do alumínio. Como a liga do qual é feito o anel contém alto teor de magnésio, se ele não estiver junto com a lata, fica mais fácil ocorrer a oxidação do alumínio no forno. A tabela apresenta as semirreações e os valores de potencial padrão de redução de alguns metais:","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":799},"LeftTop":{"X":944,"Y":304},"RightBottom":{"X":1681,"Y":799},"RightTop":{"X":1681,"Y":304}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"table","Text":"<table><tr><td>Semirreação</td><td>Potencial Padrão de Redução (V)</td></tr><tr><td>$Li^{+}$ + $e^{-}$ → Li</td><td>-3,05</td></tr><tr><td>$ K^++e^-\\to K $</td><td>-2,93</td></tr><tr><td>$ \\text{Mg}^{2+}+2\\,\\text{e}^{-}\\rightarrow\\text{Mg} $</td><td>-2,36</td></tr><tr><td>$Al^{3+}$ + 3 $e^{-}$ → Al</td><td>-1,66</td></tr><tr><td>$ \\text{Zn}^{2+}+2\\,\\text{e}^{-}\\rightarrow\\text{Zn} $</td><td>-0,76</td></tr><tr><td>$ \\text{Cu}^{2+}+2\\,\\text{e}^{-}\\rightarrow\\text{Cu} $</td><td>+0,34</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1463},"LeftTop":{"X":942,"Y":834},"RightBottom":{"X":1703,"Y":1463},"RightTop":{"X":1703,"Y":834}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"Disponível em: www.sucatas.com. Acesso em: 28 fev. 2012\n(adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":1038,"Y":1554},"LeftTop":{"X":1038,"Y":1491},"RightBottom":{"X":1681,"Y":1554},"RightTop":{"X":1681,"Y":1491}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"Com base no texto e na tabela, que metais poderiam entrar na composição do anel das latas com a mesma função do magnésio, ou seja, proteger o alumínio da oxidação nos fornos e não deixar diminuir o rendimento da sua reciclagem?","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1781},"LeftTop":{"X":944,"Y":1582},"RightBottom":{"X":1681,"Y":1781},"RightTop":{"X":1681,"Y":1582}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"Somente o lítio, pois ele possui o menor potencial de redução.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1890},"LeftTop":{"X":944,"Y":1812},"RightBottom":{"X":1695,"Y":1890},"RightTop":{"X":1695,"Y":1812}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"B Somente o cobre, pois ele possui o maior potencial de redução.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":2001},"LeftTop":{"X":944,"Y":1920},"RightBottom":{"X":1695,"Y":2001},"RightTop":{"X":1695,"Y":1920}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"paragraph","Text":"Somente o potássio, pois ele possui potencial de redução mais próximo do magnésio.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":2110},"LeftTop":{"X":944,"Y":2029},"RightBottom":{"X":1695,"Y":2110},"RightTop":{"X":1695,"Y":2029}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"paragraph","Text":"D Somente o cobre e o zinco, pois eles sofrem oxidação mais facilmente que o alumínio.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":2213},"LeftTop":{"X":944,"Y":2137},"RightBottom":{"X":1695,"Y":2213},"RightTop":{"X":1695,"Y":2137}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":27,"Type":"paragraph","Text":"E Somente o lítio e o potássio, pois seus potenciais de redução são menores do que o do alumínio.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":2324},"LeftTop":{"X":944,"Y":2244},"RightBottom":{"X":1695,"Y":2324},"RightTop":{"X":1695,"Y":2244}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":28,"Type":"footer","Text":"Página 92","Level":0,"Polygon":{"LeftBottom":{"X":1704,"Y":2390},"LeftTop":{"X":1704,"Y":2228},"RightBottom":{"X":1765,"Y":2390},"RightTop":{"X":1765,"Y":2228}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":29,"Type":"footer","Text":"Competência 3 | Natureza por Habilidades e Dificuldades dos Itens","Level":0,"Polygon":{"LeftBottom":{"X":490,"Y":2481},"LeftTop":{"X":490,"Y":2443},"RightBottom":{"X":1315,"Y":2481},"RightTop":{"X":1315,"Y":2443}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}