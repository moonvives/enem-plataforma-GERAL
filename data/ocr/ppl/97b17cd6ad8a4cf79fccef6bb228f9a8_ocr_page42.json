700}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Questão 047 (H3 | 2023 | 385,1) 1 ②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":933},"LeftTop":{"X":101,"Y":890},"RightBottom":{"X":779,"Y":933},"RightTop":{"X":779,"Y":890}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"Os mais antigos cozinhavam o feijão na panela de ferro a fim de acabar com a palidez de seus filhos. Alguns chegavam até a colocar um prego enferrujado nesse cozimento para liberar o ferro contido nele. Sabe-se que esse elemento pode ser encontrado na sua forma metálica ou iônica, sendo essencial para a manutenção da vida humana.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1251},"LeftTop":{"X":99,"Y":963},"RightBottom":{"X":842,"Y":1251},"RightTop":{"X":842,"Y":963}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"As estratégias citadas eram utilizadas com o objetivo de","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1349},"LeftTop":{"X":99,"Y":1281},"RightBottom":{"X":838,"Y":1349},"RightTop":{"X":838,"Y":1281}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"A tratar a diarreia.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1423},"LeftTop":{"X":104,"Y":1387},"RightBottom":{"X":388,"Y":1423},"RightTop":{"X":388,"Y":1387}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"B prevenir a anemia.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1493},"LeftTop":{"X":104,"Y":1455},"RightBottom":{"X":429,"Y":1493},"RightTop":{"X":429,"Y":1455}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"C evitar as verminoses.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1564}