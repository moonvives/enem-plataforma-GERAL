cleta B. Pode-se considerar que as massas de ar comprimido no pneu da bicicleta A, MA, e no pneu da bicicleta B, MB, são diretamente proporcionais aos seus volumes.","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1574},"LeftTop":{"X":938,"Y":1049},"RightBottom":{"X":1679,"Y":1574},"RightTop":{"X":1679,"Y":1049}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":28,"Type":"paragraph","Text":"Comparando as pressões e massas de ar comprimido nos pneus das bicicletas, temos:","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1673},"LeftTop":{"X":938,"Y":1602},"RightBottom":{"X":1679,"Y":1673},"RightTop":{"X":1679,"Y":1602}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":29,"Type":"paragraph","Text":"A $pA < PB \\ e M A < m B$","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1738},"LeftTop":{"X":944,"Y":1700},"RightBottom":{"X":1269,"Y":1738},"RightTop":{"X":1269,"Y":1700}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":30,"Type":"paragraph","Text":"B $pA > PB \\ e M A < m B$","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1804},"LeftTop":{"X":944,"Y":1766},"RightBottom":{"X":1269,"Y":1804},"RightTop":{"X":1269,"Y":1766}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":31,"Type":"paragraph","Text":"© pA> pB  e  mA=mB","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1870},"LeftTop":{"X":944,"Y":1829},"RightBottom":{"X":1269,"Y":1870},"RightTop":{"X":1269,"Y":1829}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":32,"Type":"paragraph","Text":"Ⓓ $pA < PB \\ e M A = mB$","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1933},"LeftTop":{"X":944,"Y":1895},"RightBottom":{"X":1269,"Y":1933},"RightTop":{"X":1269,"Y":1895}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":33,"Type":"paragraph","Text":"E $pA > pB \\ e M_A > m_B$","Level