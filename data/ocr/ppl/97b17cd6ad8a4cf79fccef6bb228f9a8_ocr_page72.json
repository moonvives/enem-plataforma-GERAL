{"PageNumber":72,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"Discard_type","Text":"H6: Compreensão de Manuais e Instruções","Level":0,"Polygon":{"LeftBottom":{"X":506,"Y":152},"LeftTop":{"X":506,"Y":104},"RightBottom":{"X":1283,"Y":152},"RightTop":{"X":1283,"Y":104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"header","Text":"Professor Professor Redão","Level":0,"Polygon":{"LeftBottom":{"X":1447,"Y":220},"LeftTop":{"X":1447,"Y":109},"RightBottom":{"X":1683,"Y":220},"RightTop":{"X":1683,"Y":109}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"title","Text":"#  Questão 109 (H6 | 2018 | 646,1) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":271},"LeftTop":{"X":101,"Y":230},"RightBottom":{"X":777,"Y":271},"RightTop":{"X":777,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"A identificação de riscos de produtos perigosos para o transporte rodoviário é obrigatória e realizada por meio da sinalização composta por um painel de segurança, de cor alaranjada, e um rótulo de risco. As informações inseridas no painel de segurança e no rótulo de risco, conforme determina a legislação, permitem que se identifique o produto transportado e os perigos a ele associados.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":602},"LeftTop":{"X":101,"Y":299},"RightBottom":{"X":842,"Y":602},"RightTop":{"X":842,"Y":299}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"A sinalização mostrada identifica uma substância que está sendo transportada em um caminhão.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":698},"LeftTop":{"X":101,"Y":622},"RightBottom":{"X":838,"Y":698},"RightTop":{"X":838,"Y":622}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":168,"Y":973},"LeftTop":{"X":168,"Y":723},"RightBottom":{"X":418,"Y":973},"RightTop":{"X":418,"Y":723}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"268 1005","Level":0,"Polygon":{"LeftBottom":{"X":168,"Y":973},"LeftTop":{"X":168,"Y":723},"RightBottom":{"X":418,"Y":973},"RightTop":{"X":418,"Y":723}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/534133322c231b88564a25a24ffdd4fd-image.png","group_id":-1,"group_type":""},{"Index":6,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":527,"Y":981},"LeftTop":{"X":527,"Y":723},"RightBottom":{"X":777,"Y":981},"RightTop":{"X":777,"Y":723}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"GÁS TÓXICO 2","Level":0,"Polygon":{"LeftBottom":{"X":527,"Y":981},"LeftTop":{"X":527,"Y":723},"RightBottom":{"X":777,"Y":981},"RightTop":{"X":777,"Y":723}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/a3732e76a9c3bed80b925fbd85fb7e8f-image.png","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"Os três algarismos da parte superior do painel indicam o “Número de risco”. O número 268 indica tratar-se de um gás (2), tóxico (6) e corrosivo (8). Os quatro dígitos da parte inferior correspondem ao “Número ONU”, que identifica o produto transportado.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1241},"LeftTop":{"X":101,"Y":1013},"RightBottom":{"X":842,"Y":1241},"RightTop":{"X":842,"Y":1013}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"BRASIL. Resolução n. 420, de 12/02/2004, da Agência Nacional de Transportes Terrestres (ANTT)/Ministério dos Transportes (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1352},"LeftTop":{"X":104,"Y":1263},"RightBottom":{"X":838,"Y":1352},"RightTop":{"X":838,"Y":1263}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"ABNT. NBR 7500: identificação para o transporte terrestre, manuseio, movimentação e armazenamento de produtos. Rio de Janeiro, 2004 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":143,"Y":1463},"LeftTop":{"X":143,"Y":1375},"RightBottom":{"X":838,"Y":1463},"RightTop":{"X":838,"Y":1375}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"Considerando a identificação apresentada no caminhão, o código 1005 corresponde à substância","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1564},"LeftTop":{"X":101,"Y":1491},"RightBottom":{"X":838,"Y":1564},"RightTop":{"X":838,"Y":1491}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"Aeteno (C2H4).","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1630},"LeftTop":{"X":101,"Y":1589},"RightBottom":{"X":352,"Y":1630},"RightTop":{"X":352,"Y":1589}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"B nitrogênio ($N_2$).","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1698},"LeftTop":{"X":102,"Y":1655},"RightBottom":{"X":379,"Y":1698},"RightTop":{"X":379,"Y":1655}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"© amônia ($NH_3$).","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1761},"LeftTop":{"X":101,"Y":1721},"RightBottom":{"X":368,"Y":1761},"RightTop":{"X":368,"Y":1721}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"D propano ($C_3H_8$).","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1827},"LeftTop":{"X":101,"Y":1784},"RightBottom":{"X":393,"Y":1827},"RightTop":{"X":393,"Y":1784}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"E dióxido de carbono ($CO_2$).","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1890},"LeftTop":{"X":101,"Y":1847},"RightBottom":{"X":533,"Y":1890},"RightTop":{"X":533,"Y":1847}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"title","Text":"#  Questão 110 (H6 | 2020 | 673,0) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":2014},"LeftTop":{"X":101,"Y":1971},"RightBottom":{"X":777,"Y":2014},"RightTop":{"X":777,"Y":1971}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"Mesmo para peixes de aquário, como o peixe arcoíris, a temperatura da água fora da faixa ideal (26 °C a 28 °C), bem como sua variação brusca, pode afetar a saúde do animal. Para manter a temperatura da água dentro do aquário na média desejada, utilizam-se dispositivos de aquecimento com termostato. Por exemplo, para um aquário de 50 L, pode-se utilizar um sistema de aquecimento de 50 W otimizado para suprir sua taxa de resfriamento.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":2380},"LeftTop":{"X":101,"Y":2039},"RightBottom":{"X":842,"Y":2380},"RightTop":{"X":842,"Y":2039}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"Essa taxa pode ser considerada praticamente constante, já que a temperatura externa ao aquário é mantida pelas estufas. Utilize para a água o calor específico 4,0 kJ kg⁻$^{1}$ K⁻$^{1}$ e a densidade 1 kg L⁻$^{1}$.","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":395},"LeftTop":{"X":938,"Y":233},"RightBottom":{"X":1679,"Y":395},"RightTop":{"X":1679,"Y":233}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"Se o sistema de aquecimento for desligado por 1 h, qual o valor mais próximo para a redução da temperatura da água do aquário?","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":541},"LeftTop":{"X":938,"Y":425},"RightBottom":{"X":1679,"Y":541},"RightTop":{"X":1679,"Y":425}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"A 4,0°C","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":607},"LeftTop":{"X":944,"Y":569},"RightBottom":{"X":1101,"Y":607},"RightTop":{"X":1101,"Y":569}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"Ⓡ 3,6°C","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":670},"LeftTop":{"X":944,"Y":632},"RightBottom":{"X":1101,"Y":670},"RightTop":{"X":1101,"Y":632}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"© 0,9℃","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":736},"LeftTop":{"X":944,"Y":698},"RightBottom":{"X":1101,"Y":736},"RightTop":{"X":1101,"Y":698}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"D 0,6℃","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":799},"LeftTop":{"X":944,"Y":761},"RightBottom":{"X":1101,"Y":799},"RightTop":{"X":1101,"Y":761}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"E 0,3°C","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":867},"LeftTop":{"X":944,"Y":829},"RightBottom":{"X":1101,"Y":867},"RightTop":{"X":1101,"Y":829}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"title","Text":"##  Questão 111 (H6 | 2021 | 677,4) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":991},"LeftTop":{"X":938,"Y":948},"RightBottom":{"X":1620,"Y":991},"RightTop":{"X":1620,"Y":948}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"paragraph","Text":"Analisando a ficha técnica de um automóvel popular, verificam-se algumas características em relação ao seu desempenho. Considerando o mesmo automóvel em duas versões, uma delas funcionando a álcool e outra, a gasolina, tem-se os dados apresentados no quadro, em relação ao desempenho de cada motor.","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":1281},"LeftTop":{"X":936,"Y":1016},"RightBottom":{"X":1679,"Y":1281},"RightTop":{"X":1679,"Y":1016}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":27,"Type":"table","Text":"<table><tr><td>Parâmetro</td><td>Motor a gasolina</td><td>Motor a álcool</td></tr><tr><td>Aceleração</td><td>de 0 a 100 km/h em 13,4 s</td><td>de 0 a 100 km/h em 12,9 s</td></tr><tr><td>Velocidade máxima</td><td>165 km/h</td><td>163 km/h</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1579},"LeftTop":{"X":938,"Y":1311},"RightBottom":{"X":1681,"Y":1579},"RightTop":{"X":1681,"Y":1311}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":28,"Type":"paragraph","Text":"Considerando desprezível a resistência do ar, qual versão apresenta a maior potência?","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1680},"LeftTop":{"X":938,"Y":1607},"RightBottom":{"X":1679,"Y":1680},"RightTop":{"X":1679,"Y":1607}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":29,"Type":"paragraph","Text":"A Como a versão a gasolina consegue a maior aceleração, esta é a que desenvolve a maior potência.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1822},"LeftTop":{"X":944,"Y":1708},"RightBottom":{"X":1695,"Y":1822},"RightTop":{"X":1695,"Y":1708}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":30,"Type":"paragraph","Text":"B Como a versão a gasolina atinge o maior valor de energia cinética, esta é a que desenvolve a maior potência.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1961},"LeftTop":{"X":944,"Y":1844},"RightBottom":{"X":1695,"Y":1961},"RightTop":{"X":1695,"Y":1844}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":31,"Type":"paragraph","Text":"ⓒ Como a versão a álcool apresenta a maior taxa de variação de energia cinética, esta é a que desenvolve a maior potência.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":2097},"LeftTop":{"X":944,"Y":1986},"RightBottom":{"X":1695,"Y":2097},"RightTop":{"X":1695,"Y":1986}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":32,"Type":"paragraph","Text":"Ⓓ Como ambas as versões apresentam a mesma variação de velocidade no cálculo da aceleração, a potência desenvolvida é a mesma.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":2233},"LeftTop":{"X":944,"Y":2122},"RightBottom":{"X":1695,"Y":2233},"RightTop":{"X":1695,"Y":2122}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":33,"Type":"paragraph","Text":"E Como a versão a gasolina fica com o motor trabalhando por mais tempo para atingir os 100 km/h, esta é a que desenvolve a maior potência.","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":2375},"LeftTop":{"X":944,"Y":2259},"RightBottom":{"X":1695,"Y":2375},"RightTop":{"X":1695,"Y":2259}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":34,"Type":"footer","Text":"Página 78","Level":0,"Polygon":{"LeftBottom":{"X":1704,"Y":2388},"LeftTop":{"X":1704,"Y":2226},"RightBottom":{"X":1763,"Y":2388},"RightTop":{"X":1763,"Y":2226}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":35,"Type":"footer","Text":"Competência 2 | Natureza por Habilidades e Dificuldades dos Itens","Level":0,"Polygon":{"LeftBottom":{"X":488,"Y":2479},"LeftTop":{"X":488,"Y":2441},"RightBottom":{"X":1315,"Y":2479},"RightTop":{"X":1315,"Y":2441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}