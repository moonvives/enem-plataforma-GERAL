up_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"● -6,2 V.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1531},"LeftTop":{"X":101,"Y":1493},"RightBottom":{"X":276,"Y":1531},"RightTop":{"X":276,"Y":1493}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"title","Text":"#  Questão 103 (H5 | 2022 | Anulada pela TRI)","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1668},"LeftTop":{"X":101,"Y":1627},"RightBottom":{"X":727,"Y":1668},"RightTop":{"X":727,"Y":1627}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Uma lanterna funciona com três pilhas de resistência interna igual a 0,5 $\\Omega$ cada, ligadas em série. Quando posicionadas corretamente, devem acender a lâmpada incandescente de especificações 4,5 W e 4,5 V. Cada pilha na posição correta gera uma f.e.m. (força eletromotriz) de 1,5 V. Uma pessoa, ao trocar as pilhas da lanterna, comete o equívoco de inverter a posição de uma das pilhas. Considere que as pilhas mantêm contato independentemente da posição.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1895},"LeftTop":{"X":101,"Y":1690},"RightBottom":{"X":1683,"Y":1895},"RightTop":{"X":1683,"Y":1690}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"Com esse equívoco, qual é a intensidade de corrente que passa pela lâmpada ao se ligar a lanterna?","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1961},"LeftTop":{"X":97,"Y":1923},"RightBottom":{"X":1522,"Y":1961},"RightTop":{"X":1522,"Y":1923}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"A 0,25 A","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":2029},"LeftTop":{"X":101,"Y":1991},"RightBottom":{"X":259,"Y":2029},"RightTop":{"X":259,"Y":1991}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":