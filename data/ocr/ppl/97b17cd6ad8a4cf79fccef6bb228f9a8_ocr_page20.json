:"","group_id":-1,"group_type":""},{"Index":27,"Type":"paragraph","Text":"● 108 questões difíceis;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":925},"LeftTop":{"X":995,"Y":890},"RightBottom":{"X":1360,"Y":925},"RightTop":{"X":1360,"Y":890}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":28,"Type":"paragraph","Text":"● 54 questões muito difíceis.","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":970},"LeftTop":{"X":995,"Y":935},"RightBottom":{"X":1424,"Y":970},"RightTop":{"X":1424,"Y":935}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":29,"Type":"paragraph","Text":"Porém, a realidade encontrada nos microdados difere dessa expectativa, o que era alertado no livro citado. Considerando as faixas indicadas, teríamos:","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1125},"LeftTop":{"X":938,"Y":1003},"RightBottom":{"X":1679,"Y":1125},"RightTop":{"X":1679,"Y":1003}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":30,"Type":"paragraph","Text":"● 0 questões muito fáceis;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1195},"LeftTop":{"X":995,"Y":1160},"RightBottom":{"X":1395,"Y":1195},"RightTop":{"X":1395,"Y":1160}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":31,"Type":"paragraph","Text":"● 3 questões fáceis;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1241},"LeftTop":{"X":995,"Y":1205},"RightBottom":{"X":1310,"Y":1241},"RightTop":{"X":1310,"Y":1205}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":32,"Type":"paragraph","Text":"● 46 questões medianas;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1286},"LeftTop":{"X":995,"Y":1251},"RightBottom":{"X":1381,"Y":1286},"RightTop":{"X":1381,"Y":1251}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":33,"Type":"paragraph","Text":"● 158 questões difíceis;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1332},"LeftTop":{"X":995,"Y":1296},"RightBottom":{"X":1360,"Y":1332},"RightTop":{"X":1360,"Y":1296}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":34,"Type":"paragraph","Text":"● 324 questões muito difíceis;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1377},"LeftTop":{"X":995,"Y":1342},"RightBottom":{"X":1445,"Y":1377},"RightTop":{"X":1445,"Y":1342}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":35,"Type":"paragraph","Text":"● além de 9 questões anuladas (8 pela TRI).","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1425},"LeftTop":{"X":995,"Y":1387},"RightBottom":{"X":1669,"Y":1425},"RightTop":{"X":1669,"Y":1387}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":36,"Type":"paragraph","Text":"Como corrigir essa distorção? Bom, farei aqui uma proposta baseada na análise dos microdados das 540 questões dos anos de 2012 a 2023, no qual a dificuldade média foi de 646,6 em Ciências da Natureza, além de um desvio padrão de 81,1. Usando esses valores, em conjunto com os dados da tabela do referido livro e uma aproximação para efeito de simplificação das análises, considerarei como itens:","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1837},"LeftTop":{"X":938,"Y":1455},"RightBottom":{"X":1679,"Y":1837},"RightTop":{"X":1679,"Y":1455}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":37,"Type":"paragraph","Text":"● Muito fáceis: dificuldade inferior a 560,0;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1908},"LeftTop":{"X":995,"Y":1872},"RightBottom":{"X":1645,"Y":1908},"RightTop":{"X":1645,"Y":1872}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":38,"Type":"paragraph","Text":"● Fáceis: dificuldade de 560,0 a 619,9;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1953},"LeftTop":{"X":995,"Y":1920},"RightBottom":{"X":1576,"Y":1953},"RightTop":{"X":1576,"Y":1920}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":39,"Type":"paragraph","Text":"● Medianos: dificuldade de 620,0 a 679,9;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":1999},"LeftTop":{"X":995,"Y":1963},"RightBottom":{"X":1622,"Y":1999},"RightTop":{"X":1622,"Y":1963}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":40,"Type":"paragraph","Text":"● Difíceis: dificuldade de 680,0 a 739,9;","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":2042},"LeftTop":{"X":995,"Y":2009},"RightBottom":{"X":1590,"Y":2042},"RightTop":{"X":1590,"Y":2009}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":41,"Type":"paragraph","Text":"● Muito difíceis: dificuldade a partir de 740,0.","Level":0,"Polygon":{"LeftBottom":{"X":995,"Y":2090},"LeftTop":{"X":995,"Y":2054},"RightBottom":{"X":1679,"Y":2090},"RightTop":{"X":1679,"Y":2054}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":42,"Type":"paragraph","Text":"Assim, teremos, neste material, 64 itens considerados como muito fáceis (1), 126 como fáceis (2), 185 como medianos (3), 108 como difíceis (4) e 48 como muito difíceis (5), o que considero bem próximo ao esperado de uma avaliação educacional como o ENEM!","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":2385},"LeftTop":{"X":938,"Y":2122},"RightBottom":{"X":1681,"Y":2385},"RightTop":{"X":1681,"Y":2122}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":43,"Type":"footer","Text":"Página 26","Level":0,"Polygon":{"LeftBottom":{"X":1706,"Y":2390},"LeftTop":{"X":1706,"Y":2226},"RightBottom":{"X":1763,"Y":2390},"RightTop":{"X":1763,"Y":2226}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":44,"Type":"footer","Text":"Dificuldades dos Itens | Natureza por Habilidades e Dificuldades dos Itens","Level":0,"Pol