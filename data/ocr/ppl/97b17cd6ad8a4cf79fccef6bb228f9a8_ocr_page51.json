cação está em desacordo com o modelo clássico de corrente.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":738},"LeftTop":{"X":940,"Y":304},"RightBottom":{"X":1683,"Y":738},"RightTop":{"X":1683,"Y":304}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"De acordo com o modelo mencionado, o fato de a lâmpada acender quase instantaneamente está relacionado à rapidez com que","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":897},"LeftTop":{"X":940,"Y":771},"RightBottom":{"X":1683,"Y":897},"RightTop":{"X":1683,"Y":771}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"A o fluido elétrico se desloca no circuito.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":968},"LeftTop":{"X":942,"Y":928},"RightBottom":{"X":1544,"Y":968},"RightTop":{"X":1544,"Y":928}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"Ⓑas cargas negativas móveis atravessam o circuito.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1079},"LeftTop":{"X":942,"Y":1001},"RightBottom":{"X":1697,"Y":1079},"RightTop":{"X":1697,"Y":1001}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"paragraph","Text":"a bateria libera cargas móveis para o filamento da lâmpada.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1195},"LeftTop":{"X":942,"Y":1112},"RightBottom":{"X":1697,"Y":1195},"RightTop":{"X":1697,"Y":1112}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"paragraph","Text":"o campo elétrico se estabelece em todos os pontos do circuito.","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1306},"LeftTop":{"X":942,"Y":1223},"RightBottom":{"X":1697,"Y":1306},"RightTop":{"X":1697,"Y":1223}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":27,"Type":"paragraph","T