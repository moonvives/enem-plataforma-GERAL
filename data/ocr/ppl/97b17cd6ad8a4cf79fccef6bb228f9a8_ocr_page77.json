tBottom":{"X":102,"Y":2350},"LeftTop":{"X":102,"Y":2304},"RightBottom":{"X":220,"Y":2350},"RightTop":{"X":220,"Y":2304}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"Questão 123 (H7 | 2014 | 610,6) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":273},"LeftTop":{"X":938,"Y":228},"RightBottom":{"X":1622,"Y":273},"RightTop":{"X":1622,"Y":228}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"As lentes fotocromáticas escurecem quando expostas à luz solar por causa de reações químicas reversíveis entre uma espécie incolor e outra colorida. Diversas reações podem ser utilizadas, e a escolha do melhor reagente para esse fim se baseia em três principais aspectos: (i) o quanto escurece a lente; (ii) o tempo de escurecimento quando exposta à luz solar; e (iii) o tempo de esmaecimento em ambiente sem forte luz solar. A transmitância indica a razão entre a quantidade de luz que atravessa o meio e a quantidade de luz qu incide sobre ele.","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":799},"LeftTop":{"X":936,"Y":304},"RightBottom":{"X":1686,"Y":799},"RightTop":{"X":1686,"Y":304}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Durante um teste de controle para o desenvolvimento de novas lentes fotocromáticas, foram analisadas cinco amostras, que utilizam reagentes químicos diferentes. No quadro, são apresentados os resultados.","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":1046},"LeftTop":{"X":936,"Y":827},"RightBottom":{"X":1686,"Y":1046},"RightTop":{"X":1686,"Y":827}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"table","Text":"<table><tr><td>Amostra</td><td>Tempo de escurecimento (segundo)</td><td>Tempo de esmaecimento (segundo)</td><td>Transmitância média da lente quando exposta à luz solar (%)</td></tr><tr><td>1</td><td>20</td><td>50</td><td>80</td></tr><tr><td>2</td><td>40</td><td>30</td><td>90</td></tr><tr><td>3</td><td>20</td><td>30</td><td>50</td></tr><tr><td>4</td><td>50</td><td>50</td><td>50</td></tr><tr><td>5</td><td>40</td><td>20</td><td>95</td></tr></table>","Level":0,"Polygon":{"LeftBottom":{"X":938,"Y":1410},"LeftTop":{"X":938,"Y":1072},"RightBottom":{"X":1713,"Y":1410},"RightTop":{"X":1713,"Y":1072}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"Considerando os três aspectos, qual é a melhor amostra de lente fotocromática para se utilizar em óculos?","Level":0,"Polygon":{"LeftBottom":{"X":936,"Y":1574},"LeftTop":{"X":936,"Y":1440},"RightBottom":{"X":1686,"Y":1574},"RightTop":{"X":1686,"Y":1440}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"A 1","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1647},"LeftTop":{"X":942,"Y":1605},"RightBottom":{"X":1029,"Y":1647},"RightTop":{"X":1029,"Y":1605}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"B 2","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1721},"LeftTop":{"X":942,"Y":1678},"RightBottom":{"X":1029,"Y":1721},"RightTop":{"X":1029,"Y":1678}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"© 3","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1791},"LeftTop":{"X":942,"Y":1751},"RightBottom":{"X":1029,"Y":1791},"RightTop":{"X":1029,"Y":1751}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"D 4","Level":0,"Polygon":{"LeftBottom":{"X":942,"Y":1867},"LeftTop":{"X":942,"Y":1822},"RightBottom":{"X":1029,"Y":1867},"RightTop":{"X":1029,"Y":1822}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"