{"PageNumber":35,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"Discard_type","Text":"H2: Ciência, Tecnologia e Solução de Problemas","Level":0,"Polygon":{"LeftBottom":{"X":454,"Y":152},"LeftTop":{"X":454,"Y":102},"RightBottom":{"X":1333,"Y":152},"RightTop":{"X":1333,"Y":102}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"header","Text":"Professor Fredão","Level":0,"Polygon":{"LeftBottom":{"X":1451,"Y":256},"LeftTop":{"X":1451,"Y":104},"RightBottom":{"X":1685,"Y":256},"RightTop":{"X":1685,"Y":104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"title","Text":"#  Questão 029 (H2 | 2021 | 559,1) 1 ②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":95,"Y":273},"LeftTop":{"X":95,"Y":228},"RightBottom":{"X":777,"Y":273},"RightTop":{"X":777,"Y":228}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"O emprego de células de combustível a hidrogênio pode ser uma tecnologia adequada ao transporte automotivo. O quadro apresenta características de cinco tecnologias mais proeminentes de células de combustível.","Level":0,"Polygon":{"LeftBottom":{"X":95,"Y":379},"LeftTop":{"X":95,"Y":296},"RightBottom":{"X":1676,"Y":379},"RightTop":{"X":1676,"Y":296}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"table","Text":"<table><tr><td>Tipo de célula de combustível</td><td>Temperatura operacional (°C)</td><td>Eletrólito</td><td>Semirreações nos eletrodos</td></tr><tr><td>AFC</td><td>90 - 100</td><td>Hidróxido de potássio aquoso</td><td>$H_{2}$ + 2 $OH^{-}$ → 2 $H_{2}O$ + 2 $e^{-}$1/2 $O_{2}$ + $H_{2}O$ + 2 $e^{-}$ → 2 $OH^{-}$</td></tr><tr><td>MSFC</td><td>600 - 1 000</td><td>Carbonatos de lítio, sódio e/ou potássio fundidos</td><td>$H_{2}$ + $CO_{3}^{2-}$ → $H_{2}O$ + $CO_{2}$ + 2 $e^{-}$1/2 $O