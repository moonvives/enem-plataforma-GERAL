83,"Y":536}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Questão 169 (H10 | 2012 | 436,1) 1 ②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":720},"LeftTop":{"X":104,"Y":675},"RightBottom":{"X":801,"Y":720},"RightTop":{"X":801,"Y":675}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"Medidas de saneamento básico são fundamentais no processo de promoção de saúde e qualidade de vida da população. Muitas vezes, a falta de saneamento está relacionada com o aparecimento de várias doenças. Nesse contexto, um paciente dá entrada em um pronto atendimento relatando que há 30 dias teve contato com águas de enchente. Ainda informa que nesta localidade não há rede de esgoto e drenagem de águas pluviais e que a coleta de lixo é inadequada. Ele apresenta os seguintes sintomas: febre, dor de cabeça e dores musculares.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":955},"LeftTop":{"X":99,"Y":746},"RightBottom":{"X":1683,"Y":955},"RightTop":{"X":1683,"Y":746}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Disponível em: http://portal.saude.gov.br. Acesso em: 27 fev. 2012 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":835,"Y":1013},"LeftTop":{"X":835,"Y":978},"RightBottom":{"X":1679,"Y":1013},"RightTop":{"X":1679,"Y":978}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"Relacionando os sintomas apresentados com as condições sanitárias da localidade, há indicações de que o paciente apresenta um caso de","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1117},"LeftTop":{"X":99,"Y":1036},"RightBottom":{"X":1679,"Y":1117},"RightTop":{"X":1679,"Y":1036}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"A difteria.","Level":0,