eu durante as décadas de 1950 e 1960, como resultado dos testes nucleares realizados na atmosfera. O estrôncio-90 pode se acumular nos organismos vivos e em cadeias alimentares e, em razão de sua semelhança química, pode participar no equilíbrio com carbonato e substituir o cálcio em diversos processos biológicos.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1857},"LeftTop":{"X":99,"Y":1615},"RightBottom":{"X":1683,"Y":1857},"RightTop":{"X":1683,"Y":1615}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"FIGUEIRA, R. C. L.; CUNHA, I. I. L. A contaminação dos oceanos por radionucídeos antropogênicos. Química Nova, n. 21, 1998 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":161,"Y":1913},"LeftTop":{"X":161,"Y":1875},"RightBottom":{"X":1679,"Y":1913},"RightTop":{"X":1679,"Y":1875}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"Ao entrar numa cadeia alimentar da qual o homem faz parte, em qual tecido do organismo humano o estrôncio-90 será acumulado predominantemente?","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":2014},"LeftTop":{"X":99,"Y":1933},"RightBottom":{"X":1683,"Y":2014},"RightTop":{"X":1683,"Y":1933}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"A Cartilaginoso.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2082},"LeftTop":{"X":104,"Y":2039},"RightBottom":{"X":367,"Y":2082},"RightTop":{"X":367,"Y":2039}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"B Sanguíneo.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2148},"LeftTop":{"X":104,"Y":2107},"RightBottom":{"X":333,"Y":2148},"RightTop":{"X":333,"Y":2107}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"C Muscular.","Level":0,"Polygon":{