{"PageNumber":50,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"H3: Ciência versus Senso Comum","Level":0,"Polygon":{"LeftBottom":{"X":588,"Y":147},"LeftTop":{"X":588,"Y":104},"RightBottom":{"X":1199,"Y":147},"RightTop":{"X":1199,"Y":104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"header","Text":"Professor Redão","Level":0,"Polygon":{"LeftBottom":{"X":1444,"Y":256},"LeftTop":{"X":1444,"Y":91},"RightBottom":{"X":1686,"Y":256},"RightTop":{"X":1686,"Y":91}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"title","Text":"#  Questão 063 (H3 | 2014 | 675,4) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":273},"LeftTop":{"X":101,"Y":230},"RightBottom":{"X":777,"Y":273},"RightTop":{"X":777,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"Para entender os movimentos dos corpos, Galileu discutiu o movimento de uma esfera de metal em dois planos inclinados sem atritos e com a possibilidade de se alterarem os ângulos de inclinação, conforme mostra a figura. Na descrição do experimento, quando a esfera de metal é abandonada para descer um plano inclinado de um determinado nível, ela sempre atinge, no plano ascendente, no máximo, um nível igual àquele em que foi abandonada.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":521},"LeftTop":{"X":99,"Y":301},"RightBottom":{"X":1683,"Y":521},"RightTop":{"X":1683,"Y":301}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":213,"Y":895},"LeftTop":{"X":213,"Y":556},"RightBottom":{"X":1570,"Y":895},"RightTop":{"X":1570,"Y":556}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":213,"Y":895},"LeftTop":{"X":213,"Y":556},"RightBottom":{"X":1570,"Y":895},"RightTop":{"X":1570,"Y":556}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/d4eda22b6dc61c9bf86dc1f6aa63ed41-image.png","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"Galileu e o plano inclinado. Disponível em: www.fisica.ufpb.br. Acesso em: 21 ago. 2012 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":579,"Y":960},"LeftTop":{"X":579,"Y":925},"RightBottom":{"X":1679,"Y":960},"RightTop":{"X":1679,"Y":925}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Se o ângulo de inclinação do plano de subida for reduzido a zero, a esfera","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1029},"LeftTop":{"X":101,"Y":988},"RightBottom":{"X":1145,"Y":1029},"RightTop":{"X":1145,"Y":988}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"A manterá sua velocidade constante, pois o impulso resultante sobre ela será nulo.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1102},"LeftTop":{"X":104,"Y":1056},"RightBottom":{"X":1301,"Y":1102},"RightTop":{"X":1301,"Y":1056}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"B manterá sua velocidade constante, pois o impulso da descida continuará a empurrá-la.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1175},"LeftTop":{"X":104,"Y":1132},"RightBottom":{"X":1381,"Y":1175},"RightTop":{"X":1381,"Y":1132}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"© diminuirá gradativamente a sua velocidade, pois não haverá mais impulso para empurrá-la.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1246},"LeftTop":{"X":104,"Y":1205},"RightBottom":{"X":1444,"Y":1246},"RightTop":{"X":1444,"Y":1205}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"D diminuirá gradativamente a sua velocidade, pois o impulso resultante será contrário ao seu movimento.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1319},"LeftTop":{"X":104,"Y":1276},"RightBottom":{"X":1610,"Y":1319},"RightTop":{"X":1610,"Y":1276}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"E aumentará gradativamente a sua velocidade, pois não haverá nenhum impulso contrário ao seu movimento.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1390},"LeftTop":{"X":104,"Y":1349},"RightBottom":{"X":1676,"Y":1390},"RightTop":{"X":1676,"Y":1349}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"title","Text":"#  Questão 064 (H3 | 2022 | 677,9) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1531},"LeftTop":{"X":101,"Y":1483},"RightBottom":{"X":777,"Y":1531},"RightTop":{"X":777,"Y":1483}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"Um Buraco Negro é um corpo celeste que possui uma grande quantidade de matéria concentrada em uma pequena região do espaço, de modo que sua força gravitacional é tão grande que qualquer partícula fica aprisionada em sua superfície, inclusive a luz. O raio dessa região caracteriza uma superfície-limite, chamada de horizonte de eventos, da qual nada consegue escapar. Considere que o Sol foi instantaneamente substituído por um Buraco Negro com a mesma massa solar, de modo que o seu horizonte de eventos seja de aproximadamente 3,0 km.","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1827},"LeftTop":{"X":99,"Y":1562},"RightBottom":{"X":1683,"Y":1827},"RightTop":{"X":1683,"Y":1562}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"SCHWARZSCHILD, K. On the Gravitational Field of a Mass Point According to Einstein's Theory. Disponível em: arxiv.org. Acesso em: 26 maio 2022 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":140,"Y":1925},"LeftTop":{"X":140,"Y":1852},"RightBottom":{"X":1683,"Y":1925},"RightTop":{"X":1683,"Y":1852}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"Após a substituição descrita, o que aconteceria aos planetas do Sistema Solar?","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":1991},"LeftTop":{"X":99,"Y":1951},"RightBottom":{"X":1220,"Y":1991},"RightTop":{"X":1220,"Y":1951}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"A Eles se moveriam em órbitas espirais, aproximando-se sucessivamente do Buraco Negro.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2064},"LeftTop":{"X":104,"Y":2021},"RightBottom":{"X":1426,"Y":2064},"RightTop":{"X":1426,"Y":2021}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"B Eles oscilariam aleatoriamente em torno de suas órbitas elípticas originais.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2132},"LeftTop":{"X":104,"Y":2095},"RightBottom":{"X":1210,"Y":2132},"RightTop":{"X":1210,"Y":2095}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"Eles se moveriam em direção ao centro do Buraco Negro.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":2208},"LeftTop":{"X":101,"Y":2168},"RightBottom":{"X":977,"Y":2208},"RightTop":{"X":977,"Y":2168}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"D Eles passariam a precessionar mais rapidamente.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2279},"LeftTop":{"X":104,"Y":2239},"RightBottom":{"X":865,"Y":2279},"RightTop":{"X":865,"Y":2239}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"paragraph","Text":"E Eles manteriam suas órbitas inalteradas.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2352},"LeftTop":{"X":104,"Y":2309},"RightBottom":{"X":735,"Y":2352},"RightTop":{"X":735,"Y":2309}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"footer","Text":"Página 56","Level":0,"Polygon":{"LeftBottom":{"X":1708,"Y":2390},"LeftTop":{"X":1708,"Y":2226},"RightBottom":{"X":1761,"Y":2390},"RightTop":{"X":1761,"Y":2226}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"footer","Text":"Competência 1 | Natureza por Habilidades e Dificuldades dos Itens","Level":0,"Polygon":{"LeftBottom":{"X":486,"Y":2481},"LeftTop":{"X":486,"Y":2441},"RightBottom":{"X":1317,"Y":2481},"RightTop":{"X":1317,"Y":2441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}