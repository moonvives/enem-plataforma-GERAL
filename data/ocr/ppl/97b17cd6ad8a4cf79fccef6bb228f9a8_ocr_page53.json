{"PageNumber":53,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"H4: Sustentabilidade e Conservação Ambiental","Level":0,"Polygon":{"LeftBottom":{"X":472,"Y":152},"LeftTop":{"X":472,"Y":104},"RightBottom":{"X":1315,"Y":152},"RightTop":{"X":1315,"Y":104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"header","Text":"Professor Redaw","Level":0,"Polygon":{"LeftBottom":{"X":1444,"Y":246},"LeftTop":{"X":1444,"Y":102},"RightBottom":{"X":1685,"Y":246},"RightTop":{"X":1685,"Y":102}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Questão 071 (H4 | 2012 | 526,6) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":99,"Y":273},"LeftTop":{"X":99,"Y":228},"RightBottom":{"X":777,"Y":273},"RightTop":{"X":777,"Y":228}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"Pesticidas são contaminantes ambientais altamente tóxicos aos seres vivos e, geralmente, com grande persistência ambiental. A busca por novas formas de eliminação dos pesticidas tem aumentado nos últimos anos, uma vez que as técnicas atuais são economicamente dispendiosas e paliativas. A biorremediação de pesticidas utilizando microrganismos tem se mostrado uma técnica muito promissora para essa finalidade, por apresentar vantagens econômicas e ambientais.","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":480},"LeftTop":{"X":97,"Y":294},"RightBottom":{"X":1683,"Y":480},"RightTop":{"X":1683,"Y":294}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"Para ser utilizado nesta técnica promissora, um microrganismo deve ser capaz de","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":541},"LeftTop":{"X":97,"Y":498},"RightBottom":{"X":1254,"Y":541},"RightTop":{"X":1254,"Y":498}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"A transferir o contaminante do solo para a água.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":604},"LeftTop":{"X":101,"Y":561},"RightBottom":{"X":813,"Y":604},"RightTop":{"X":813,"Y":561}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"B absorver o contaminante sem alterá-lo quimicamente.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":667},"LeftTop":{"X":101,"Y":624},"RightBottom":{"X":919,"Y":667},"RightTop":{"X":919,"Y":624}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"apresentar alta taxa de mutação ao longo das gerações.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":731},"LeftTop":{"X":101,"Y":688},"RightBottom":{"X":960,"Y":731},"RightTop":{"X":960,"Y":688}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"D estimular o sistema imunológico do homem contra o contaminante.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":794},"LeftTop":{"X":101,"Y":751},"RightBottom":{"X":1104,"Y":794},"RightTop":{"X":1104,"Y":751}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"E metabolizar o contaminante, liberando subprodutos menos tóxicos ou atóxicos.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":859},"LeftTop":{"X":101,"Y":814},"RightBottom":{"X":1274,"Y":859},"RightTop":{"X":1274,"Y":814}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"title","Text":"#  Questão 072 (H4 | 2021 | 530,9) 1 ②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":970},"LeftTop":{"X":101,"Y":925},"RightBottom":{"X":777,"Y":970},"RightTop":{"X":777,"Y":925}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index