":"","group_id":-1,"group_type":""},{"Index":10,"Type":"paragraph","Text":"Criação de novas partículas eletrizadas nos pelos do gato.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1084},"LeftTop":{"X":101,"Y":1039},"RightBottom":{"X":985,"Y":1084},"RightTop":{"X":985,"Y":1039}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"D Movimentação de elétrons entre a calça e os pelos do gato.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1152},"LeftTop":{"X":101,"Y":1107},"RightBottom":{"X":1001,"Y":1152},"RightTop":{"X":1001,"Y":1107}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"E Repulsão entre partículas elétricas da calça e dos pelos do gato.","Level":0,"Polygon":{"LeftBottom":{"X":101,"Y":1218},"LeftTop":{"X":101,"Y":1173},"RightBottom":{"X":1069,"Y":1218},"RightTop":{"X":1069,"Y":1173}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"title","Text":"#  Questão 053 (H3 | 2021 | 565,1) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1349},"LeftTop":{"X":97,"Y":1301},"RightBottom":{"X":777,"Y":1349},"RightTop":{"X":777,"Y":1301}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"No seu estudo sobre a queda dos corpos, Aristóteles afirmava que se abandonarmos corpos leves e pesados de uma mesma altura, o mais pesado chegaria mais rápido ao solo. Essa ideia está apoiada em algo que é difícil de refutar, a observação direta da realidade baseada no senso comum.","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1493},"LeftTop":{"X":97,"Y":1370},"RightBottom":{"X":1679,"Y":1493},"RightTop":{"X":1679,"Y":1370}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"Após uma aula de física, dois colegas estavam discutindo sobre a queda dos corpos, e um tentava convencer o outro de que tinha razão:","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1597},"LeftTop":{"X":97,"Y":1514},"RightBottom":{"X":1679,"Y":1597},"RightTop":{"X":1679,"Y":1514}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"Colega A: “O corpo mais pesado cai mais rápido que um menos pesado, quando largado de uma mesma altura. Eu provo, largando uma pedra e uma rolha. A pedra chega antes. Pronto! Tá provado!”.","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1703},"LeftTop":{"X":97,"Y":1617},"RightBottom":{"X":1679,"Y":1703},"RightTop":{"X":1679,"Y":1617}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"Colega B: “Eu não acho! Peguei uma folha de papel esticado e deixei cair. Quando amassei, ela caiu mais rápido. Como isso é possível? Se era a mesma folha de papel, deveria cair do mesmo jeito. Tem que ter outra explicação!”.","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1844},"LeftTop":{"X":97,"Y":1721},"RightBottom":{"X":1679,"Y":1844},"RightTop":{"X":1679,"Y":1721}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"HÜLSENDEGER, M. Uma análise das concepções dos alunos sobre a queda dos corpos. Caderno Brasileiro de Ensino de Física, n. 3, dez. 2004 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":151,"Y":1933},"LeftTop":{"X":151,"Y":1865},"RightBottom":{"X":1679,"Y":1933},"RightTop":{"X":1679,"Y":1865}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"O aspecto físico comum que explica a diferença de comportamento dos corpos em queda nessa discussão é o(a)","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1994},"LeftTop":{"X":97,"Y":1951},"RightBottom":{"X":1679,"Y":1994},"RightTop":{"X":1679,"Y":1951}},"InsetImageName":"","Elements":null,"ImagePath":"