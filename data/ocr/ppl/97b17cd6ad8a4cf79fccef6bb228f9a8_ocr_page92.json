:1572},"LeftTop":{"X":940,"Y":1289},"RightBottom":{"X":1683,"Y":1572},"RightTop":{"X":1683,"Y":1289}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":27,"Type":"paragraph","Text":"De acordo com essa teoria, a extinção ocorreu em função de modificações no planeta que","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1680},"LeftTop":{"X":944,"Y":1599},"RightBottom":{"X":1683,"Y":1680},"RightTop":{"X":1683,"Y":1599}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":28,"Type":"paragraph","Text":"A desestabilizaram o relógio biológico dos animais, causando alterações no código genético.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":1786},"LeftTop":{"X":947,"Y":1708},"RightBottom":{"X":1692,"Y":1786},"RightTop":{"X":1692,"Y":1708}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":29,"Type":"paragraph","Text":"B reduziram a penetração da luz solar até a superfície da Terra, interferindo no fluxo energético das teias tróficas.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":1930},"LeftTop":{"X":947,"Y":1812},"RightBottom":{"X":1695,"Y":1930},"RightTop":{"X":1695,"Y":1812}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":30,"Type":"paragraph","Text":"ⓒ causaram uma série de intoxicações nos animais, provocando a bioacumulação de partículas de poeira nos organismos.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":2077},"LeftTop":{"X":947,"Y":1958},"RightBottom":{"X":1695,"Y":2077},"RightTop":{"X":1695,"Y":1958}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":31,"Type":"paragraph","Text":"D resultaram na sedimentação das partículas de poeira levantada com o impacto do meteoro, provocando o desaparecimento de rios e lagos.","Level":0,"Polygon":{"LeftBottom":{"X":947,"Y":2223},"LeftTop":{"X":947,"Y":2102},"RightBottom":{"X":1695,"Y":2223},"RightTop":{"X":1695,"Y":2102}