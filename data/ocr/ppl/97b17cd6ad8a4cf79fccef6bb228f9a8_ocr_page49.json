{"PageNumber":49,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"Discard_type","Text":"H3: Ciência versus Senso Comum","Level":0,"Polygon":{"LeftBottom":{"X":588,"Y":147},"LeftTop":{"X":588,"Y":104},"RightBottom":{"X":1199,"Y":147},"RightTop":{"X":1199,"Y":104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"header","Text":"Professor Redão","Level":0,"Polygon":{"LeftBottom":{"X":1444,"Y":246},"LeftTop":{"X":1444,"Y":96},"RightBottom":{"X":1683,"Y":246},"RightTop":{"X":1683,"Y":96}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"title","Text":"#  Questão 061 (H3 | 2017 | 635,3) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":273},"LeftTop":{"X":102,"Y":230},"RightBottom":{"X":779,"Y":273},"RightTop":{"X":779,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"paragraph","Text":"Um fato corriqueiro ao se cozinhar arroz é o derramamento de parte da água de cozimento sobre a chama azul do fogo, mudando-a para uma chama amarela. Essa mudança de cor pode suscitar interpretações diversas, relacionadas às substâncias presentes na água de cozimento. Além do sal de cozinha (NaCl), nela se encontram carboidratos, proteínas e sais minerais.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":458},"LeftTop":{"X":102,"Y":301},"RightBottom":{"X":1681,"Y":458},"RightTop":{"X":1681,"Y":301}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":4,"Type":"paragraph","Text":"Cientificamente, sabe-se que essa mudança de cor da chama ocorre pela","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":521},"LeftTop":{"X":102,"Y":483},"RightBottom":{"X":1138,"Y":521},"RightTop":{"X":1138,"Y":483}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"A reação do gás de cozinha com o sal, volatilizando gás cloro.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":584},"LeftTop":{"X":104,"Y":544},"RightBottom":{"X":1051,"Y":584},"RightTop":{"X":1051,"Y":544}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"B emissão de fótons pelo sódio, excitado por causa da chama.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":647},"LeftTop":{"X":104,"Y":609},"RightBottom":{"X":1010,"Y":647},"RightTop":{"X":1010,"Y":609}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"© produção de derivado amarelo, pela reação com o carboidrato.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":710},"LeftTop":{"X":104,"Y":675},"RightBottom":{"X":1044,"Y":710},"RightTop":{"X":1044,"Y":675}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"D reação do gás de cozinha com a água, formando gás hidrogênio.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":776},"LeftTop":{"X":104,"Y":738},"RightBottom":{"X":1072,"Y":776},"RightTop":{"X":1072,"Y":738}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"E excitação das moléculas de proteínas, com formação de luz amarela.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":839},"LeftTop":{"X":104,"Y":801},"RightBottom":{"X":1188,"Y":839},"RightTop":{"X":1188,"Y":801}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"Type":"title","Text":"#  Questão 062 (H3 | 2016 | 657,7) ①② ![](656,927,699,970)④⑤","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":968},"LeftTop":{"X":102,"Y":925},"RightBottom":{"X":779,"Y":968},"RightTop":{"X":779,"Y":925}},"InsetImageName":"","Elements":null,"ImagePath":"images/56917068c03320dbfe55126a636c971a-image.png","group_id":-1,"group_type":""},{"Index":11,"Type":"paragraph","Text":"Num experimento, um professor deixa duas bandejas de mesma massa, uma de plástico e outra de alumínio, sobre a mesa do laboratório. Após algumas horas, ele pede aos alunos que avaliem a temperatura das duas bandejas, usando para isso o tato. Seus alunos afirmam, categoricamente, que a bandeja de alumínio encontra-se numa temperatura mais baixa. Intrigado, ele propõe uma segunda atividade, em que coloca um cubo de gelo sobre cada uma das bandejas, que estão em equilíbrio térmico com o ambiente, e os questiona em qual delas a taxa de derretimento do gelo será maior.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1233},"LeftTop":{"X":102,"Y":996},"RightBottom":{"X":1683,"Y":1233},"RightTop":{"X":1683,"Y":996}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"O aluno que responder corretamente ao questionamento do professor dirá que o derretimento ocorrerá","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1294},"LeftTop":{"X":102,"Y":1258},"RightBottom":{"X":1547,"Y":1294},"RightTop":{"X":1547,"Y":1258}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"A mais rapidamente na bandeja de alumínio, pois ela tem uma maior condutividade térmica que a de plástico.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1365},"LeftTop":{"X":104,"Y":1324},"RightBottom":{"X":1663,"Y":1365},"RightTop":{"X":1663,"Y":1324}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"B mais rapidamente na bandeja de plástico, pois ela tem inicialmente uma temperatura mais alta que a de alumínio.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1466},"LeftTop":{"X":104,"Y":1392},"RightBottom":{"X":1663,"Y":1466},"RightTop":{"X":1663,"Y":1392}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"© mais rapidamente na bandeja de plástico, pois ela tem uma maior capacidade térmica que a de alumínio.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1534},"LeftTop":{"X":102,"Y":1496},"RightBottom":{"X":1640,"Y":1534},"RightTop":{"X":1640,"Y":1496}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"D mais rapidamente na bandeja de alumínio, pois ela tem um calor específico menor que a de plástico.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1602},"LeftTop":{"X":102,"Y":1564},"RightBottom":{"X":1576,"Y":1602},"RightTop":{"X":1576,"Y":1564}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"E com a mesma rapidez nas duas bandejas, pois apresentarão a mesma variação de temperatura.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":1668},"LeftTop":{"X":104,"Y":1627},"RightBottom":{"X":1517,"Y":1668},"RightTop":{"X":1517,"Y":1627}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"footer","Text":"Página 55","Level":0,"Polygon":{"LeftBottom":{"X":1704,"Y":2383},"LeftTop":{"X":1704,"Y":2231},"RightBottom":{"X":1760,"Y":2383},"RightTop":{"X":1760,"Y":2231}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"footer","Text":"Competência 1 | Natureza por Habilidades e Dificuldades dos Itens","Level":0,"Polygon":{"LeftBottom":{"X":486,"Y":2481},"LeftTop":{"X":486,"Y":2441},"RightBottom":{"X":1315,"Y":2481},"RightTop":{"X":1315,"Y":2441}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}