{"PageNumber":40,"Angle":0,"RotatedAngle":0,"Height":2526,"Width":1786,"OriginHeight":0,"OriginWidth":0,"Elements":[{"Index":0,"Type":"header","Text":"H2: Ciência, Tecnologia e Solução de Problemas","Level":0,"Polygon":{"LeftBottom":{"X":454,"Y":152},"LeftTop":{"X":454,"Y":102},"RightBottom":{"X":1331,"Y":152},"RightTop":{"X":1331,"Y":102}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":1,"Type":"paragraph","Text":"Questão 043 (H2 | 2018 | 676,5) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":95,"Y":273},"LeftTop":{"X":95,"Y":223},"RightBottom":{"X":781,"Y":273},"RightTop":{"X":781,"Y":223}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":2,"Type":"paragraph","Text":"Pesquisas demonstram que nanodispositivos baseados em movimentos de dimensões atômicas, induzidos por luz, poderão ter aplicações em tecnologias futuras, substituindo micromotores, sem a necessidade de componentes mecânicos. Exemplo de movimento molecular induzido pela luz pode ser observado pela flexão de uma lâmina delgada de silício, ligado a um polímero de azobenzeno e a um material suporte, em dois comprimentos de onda, conforme ilustrado na figura. Com a aplicação de luz ocorrem reações reversíveis da cadeia do polímero, que promovem o movimento observado.","Level":0,"Polygon":{"LeftBottom":{"X":95,"Y":544},"LeftTop":{"X":95,"Y":299},"RightBottom":{"X":1679,"Y":544},"RightTop":{"X":1679,"Y":299}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":3,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":156,"Y":1258},"LeftTop":{"X":156,"Y":581},"RightBottom":{"X":1617,"Y":1258},"RightTop":{"X":1617,"Y":581}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"$$\\begin{array}{r@{\\hspace{2em}}l}365\\text{ nm}&\\text{Átomos:}\\\\ 420\\text{ nm}&\\text{Hidrogênic}\\\\\\end{array}$$","Level":0,"Polygon":{"LeftBottom":{"X":156,"Y":1258},"LeftTop":{"