     D --> |100 Ω|","Level":0,"Polygon":{"LeftBottom":{"X":190,"Y":981},"LeftTop":{"X":190,"Y":645},"RightBottom":{"X":751,"Y":981},"RightTop":{"X":751,"Y":645}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/b6c0d33d648a14ac1fa48e54e9f46e60-image.png","group_id":-1,"group_type":""},{"Index":5,"Type":"paragraph","Text":"Ele tem um equipamento que opera em 9,0 V com uma resistência interna de 10 kΩ.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1079},"LeftTop":{"X":102,"Y":1008},"RightBottom":{"X":842,"Y":1079},"RightTop":{"X":842,"Y":1008}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":6,"Type":"paragraph","Text":"Entre quais pontos do divisor de tensão esse equipamento deve ser ligado para funcionar corretamente e qual será o valor da intensidade da corrente nele estabelecida?","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1251},"LeftTop":{"X":102,"Y":1104},"RightBottom":{"X":842,"Y":1251},"RightTop":{"X":842,"Y":1104}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":7,"Type":"paragraph","Text":"A Entre A e C; 30 mA.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1317},"LeftTop":{"X":102,"Y":1279},"RightBottom":{"X":454,"Y":1317},"RightTop":{"X":454,"Y":1279}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":8,"Type":"paragraph","Text":"Ⓑ Entre B e E; 30 mA.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1377},"LeftTop":{"X":102,"Y":1339},"RightBottom":{"X":449,"Y":1377},"RightTop":{"X":449,"Y":1339}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":9,"Type":"paragraph","Text":"ⓒ Entre A e D; 1,2mA.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1443},"LeftTop":{"X":102,"Y":1400},"RightBottom":{"X":452,"Y":1443},"RightTop":{"X":452,"Y":1400}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":10,"