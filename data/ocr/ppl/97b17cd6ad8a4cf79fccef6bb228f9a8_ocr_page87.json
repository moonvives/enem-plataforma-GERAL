roup_type":""},{"Index":11,"Type":"paragraph","Text":"Questão 141 (H8 | 2017 | 634,4) ①② ![](656,1442,699,1485)④⑤","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1486},"LeftTop":{"X":97,"Y":1438},"RightBottom":{"X":781,"Y":1486},"RightTop":{"X":781,"Y":1438}},"InsetImageName":"","Elements":null,"ImagePath":"images/2ab6a19b5e70af53f6d85eb4bba0a4e5-image.png","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"Diversos produtos naturais podem ser obtidos de plantas por processo de extração. O lapachol é da classe das naftoquinonas. Sua estrutura apresenta uma hidroxila enólica (pKₐ = 6,0) que permite que este composto seja isolado da serragem dos ipês por extração com solução adequada, seguida de filtração simples. Considere que pKₐ = -log Kₐ, em que Kₐ é a constante ácida da reação de ionização do lapachol.","Level":0,"Polygon":{"LeftBottom":{"X":97,"Y":1834},"LeftTop":{"X":97,"Y":1511},"RightBottom":{"X":842,"Y":1834},"RightTop":{"X":842,"Y":1511}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"figure","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":158,"Y":2302},"LeftTop":{"X":158,"Y":1857},"RightBottom":{"X":776,"Y":2302},"RightTop":{"X":776,"Y":1857}},"InsetImageName":"","Elements":[{"Index":0,"Type":"figure_text","Text":"","Level":0,"Polygon":{"LeftBottom":{"X":158,"Y":2302},"LeftTop":{"X":158,"Y":1857},"RightBottom":{"X":776,"Y":2302},"RightTop":{"X":776,"Y":1857}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":0,"group_type":""}],"ImagePath":"images/92a862d0e8dfc5a629e3469c118223f1-image.png","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"COSTA, P. R. R. et al. Ácidos e bases em química orgânica. Porto Alegre: Bookman, 2005 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":245,"Y":2390},"LeftTop":{"X":245,"Y":2332},"RightBottom":{"X":840,"Y":2390},"RightTop":{"X":840,"Y":2332}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_