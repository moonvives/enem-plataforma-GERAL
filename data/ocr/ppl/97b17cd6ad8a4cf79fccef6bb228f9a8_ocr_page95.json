op":{"X":195,"Y":1481}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":11,"Type":"title","Text":"#  Questão 163 (H9 | 2022 | 670,4) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1642},"LeftTop":{"X":102,"Y":1597},"RightBottom":{"X":779,"Y":1642},"RightTop":{"X":779,"Y":1597}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"Os ursos, por não apresentarem uma hibernação verdadeira, acordam por causa da presença de termogenina, uma proteína mitocondrial que impede a chegada dos prótons até a ATP sintetase, gerando calor. Esse calor é importante para aquecer o organismo, permitindo seu despertar.","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":1890},"LeftTop":{"X":102,"Y":1665},"RightBottom":{"X":838,"Y":1890},"RightTop":{"X":838,"Y":1665}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"SADAVA, D. et al. Vida: a ciência da biologia. Porto Alegres Artmed, 2009 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":181,"Y":1966},"LeftTop":{"X":181,"Y":1908},"RightBottom":{"X":838,"Y":1966},"RightTop":{"X":838,"Y":1908}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"paragraph","Text":"Em qual etapa do metabolismo energético celular a termogenina interfere?","Level":0,"Polygon":{"LeftBottom":{"X":102,"Y":2062},"LeftTop":{"X":102,"Y":1988},"RightBottom":{"X":838,"Y":2062},"RightTop":{"X":838,"Y":1988}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":15,"Type":"paragraph","Text":"A Glicóise.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2122},"LeftTop":{"X":104,"Y":2087},"RightBottom":{"X":295,"Y":2122},"RightTop":{"X":295,"Y":2087}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":16,"Type":"paragraph","Text":"B Fermentação lática.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2188},"LeftTop":{"X":104,"Y":2148},"RightBottom":{"X":445,"Y":2188},"RightTop":{"X":445,"Y":2148}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":17,"Type":"paragraph","Text":"Ciclo do ácido cítrico.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2246},"LeftTop":{"X":104,"Y":2211},"RightBottom":{"X":468,"Y":2246},"RightTop":{"X":468,"Y":2211}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":18,"Type":"paragraph","Text":"D Oxidação do piruvato.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2314},"LeftTop":{"X":104,"Y":2274},"RightBottom":{"X":477,"Y":2314},"RightTop":{"X":477,"Y":2274}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":19,"Type":"paragraph","Text":"E Fosforilação oxidativa.","Level":0,"Polygon":{"LeftBottom":{"X":104,"Y":2377},"LeftTop":{"X":104,"Y":2337},"RightBottom":{"X":483,"Y":2377},"RightTop":{"X":483,"Y":2337}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":20,"Type":"title","Text":"##  Questão 164 (H9 | 2018 | 677,7) ①②③④⑤","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":273},"LeftTop":{"X":944,"Y":230},"RightBottom":{"X":1620,"Y":273},"RightTop":{"X":1620,"Y":230}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":21,"Type":"paragraph","Text":"O alemão Fritz Haber recebeu o Prêmio Nobel de química de 1918 pelo desenvolvimento de um processo viável para a síntese da amônia ($NH_3$). Em seu discurso de premiação, Haber justificou a importância do feito dizendo que:","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":485},"LeftTop":{"X":940,"Y":296},"RightBottom":{"X":1679,"Y":485},"RightTop":{"X":1679,"Y":296}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":22,"Type":"paragraph","Text":"“Desde a metade do século passado, tornou-se conhecido que um suprimento de nitrogênio é uma necessidade básica para o aumento das safras de alimentos; entretanto, também se sabia que as plantas não podem absorver o nitrogênio em sua forma simples, que é o principal constituinte da atmosfera. Elas precisam que o nitrogênio seja combinado [...] para poderem assimilá-lo.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":811},"LeftTop":{"X":940,"Y":508},"RightBottom":{"X":1681,"Y":811},"RightTop":{"X":1681,"Y":508}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":23,"Type":"paragraph","Text":"Economias agrícolas basicamente mantêm o balanço do nitrogênio ligado. No entanto, com o advento da era industrial, os produtos do solo são levados de onde cresce a colheita para lugares distantes, onde são consumidos, fazendo com que o nitrogênio ligado não retorne à terra da qual foi retirado.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":1089},"LeftTop":{"X":940,"Y":834},"RightBottom":{"X":1681,"Y":1089},"RightTop":{"X":1681,"Y":834}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":24,"Type":"paragraph","Text":"Isso tem gerado a necessidade econômica mundial de abastecer o solo com nitrogênio ligado. [...] A demanda por nitrogênio, tal como a do carvão, indica quão diferente nosso modo de vida se tornou com relação ao das pessoas que, com seus próprios corpos, fertilizam o solo que cultivam.","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":1339},"LeftTop":{"X":940,"Y":1114},"RightBottom":{"X":1681,"Y":1339},"RightTop":{"X":1681,"Y":1114}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":25,"Type":"paragraph","Text":"Desde a metade do último século, nós vinhamos aproveitando o suprimento de nitrogênio do salitre que a natureza tinha depositado nos desertos montanhosos do Chile. Comparando o rápido crescimento da demanda com a extensão calculada desses depósitos, ficou claro que em meados do século atual uma emergência seríssima seria inevitável, a menos que a química encontrasse uma saída.\"","Level":0,"Polygon":{"LeftBottom":{"X":940,"Y":1695},"LeftTop":{"X":940,"Y":1365},"RightBottom":{"X":1681,"Y":1695},"RightTop":{"X":1681,"Y":1365}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":26,"Type":"paragraph","Text":"HABER, F. The Synthesis of Ammonia from its Elements. Disponível em: www.nobelprize.org. Acesso em: 13 jul. 2013 (adaptado).","Level":0,"Polygon":{"LeftBottom":{"X":965,"Y":1776},"LeftTop":{"X":965,"Y":1723},"RightBottom":{"X":1679,"Y":1776},"RightTop":{"X":1679,"Y":1723}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":27,"Type":"paragraph","Text":"De acordo com os argumentos de Haber, qual fenômeno teria provocado o desequilíbrio no “balanço do nitrogênio ligado”?","Level":0,"Polygon":{"LeftBottom":{"X":944,"Y":1913},"LeftTop":{"X":944,"Y":1802},"RightBottom":{"X":1681,"Y":1913},"RightTop":{"X":1681,"Y":1802}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":28,"Type":"paragraph","Text":"A O esgotamento das reservas de salitre no Chile.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":1976},"LeftTop":{"X":945,"Y":1938},"RightBottom":{"X":1681,"Y":1976},"RightTop":{"X":1681,"Y":1938}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":29,"Type":"paragraph","Text":"Ⓑ O aumento da exploração de carvão vegetal e carvão mineral.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":2074},"LeftTop":{"X":945,"Y":2001},"RightBottom":{"X":1692,"Y":2074},"RightTop":{"X":1692,"Y":2001}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":30,"Type":"paragraph","Text":"© A redução da fertilidade do solo nas economias agrícolas.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":2175},"LeftTop":{"X":945,"Y":2102},"RightBottom":{"X":1692,"Y":2175},"RightTop":{"X":1692,"Y":2102}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":31,"Type":"paragraph","Text":"Ⓓ A intensificação no fluxo de pessoas do campo para as cidades.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":2274},"LeftTop":{"X":945,"Y":2198},"RightBottom":{"X":1692,"Y":2274},"RightTop":{"X":1692,"Y":2198}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":32,"Type":"paragraph","Text":"E A necessidade das plantas de absorverem sais de nitrogenênio disponíveis no solo.","Level":0,"Polygon":{"LeftBottom":{"X":945,"Y":2372},"LeftTop":{"X":945,"Y":2299},"RightBottom":{"X":1692,"Y":2372},"RightTop":{"X":1692,"Y":2299}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":33,"Type":"footer","Text":"Página 101","Level":0,"Polygon":{"LeftBottom":{"X":1704,"Y":2388},"LeftTop":{"X":1704,"Y":2198},"RightBottom":{"X":1760,"Y":2388},"RightTop":{"X":1760,"Y":2198}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":34,"Type":"footer","Text":"Competência 3 | Natureza por Habilidades e Dificuldades dos Itens","Level":0,"Polygon":{"LeftBottom":{"X":492,"Y":2481},"LeftTop":{"X":492,"Y":2443},"RightBottom":{"X":1317,"Y":2481},"RightTop":{"X":1317,"Y":2443}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}